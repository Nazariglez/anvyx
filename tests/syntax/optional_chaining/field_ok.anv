// @mode: check
// @expect: success

struct Stats {
    hp: int,
}

struct Player {
    score: int,
    name: string,
    stats: Stats,
}

fn main() {
    let p: Player? = Player { score: 100, name: "Naza", stats: Stats { hp: 100 } };
    let s: int? = p?.score;
    let n: string? = p?.name;

    let hp: int? = p?.stats.hp;

    let v: int = p?.score ?? 0;

    let q: Player? = nil;
    let qs: int? = q?.score;
    let qv: int = q?.score ?? 42;
}
