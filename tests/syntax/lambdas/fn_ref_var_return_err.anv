// @mode: run
// @expect: error
// @contains: contains 'return' and cannot be inlined
// @skip: this should be easily fixable changing returns for "continue" on lower phase?

fn early_exit(var x: int) {
    if x > 10 {
        return;
    }
    x += 1;
}

fn main() {
    var xs: [int] = [1, 20, 3];
    xs.for_each(early_exit);
}
