// @mode: check
// @expect: success

struct Container<T> {
    items: [T],
}

fn main() {
    let nums: [int] = [1, 2, 3];
    let c = Container { items: nums };
    let _: [int] = c.items;

    let strs: [string] = ["a", "b"];
    let d = Container { items: strs };
    let _: [string] = d.items;
}
