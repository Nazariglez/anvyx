// @mode: check
// @expect: success

fn relay<T>(xs: [T; ..]) -> T {
    xs[0]
}

fn pass_through<T>(xs: [T; ..]) -> T {
    relay(xs)
}

fn main() {
    let arr = [10, 20, 30];
    let a = pass_through(arr);
    let _: int = a;

    let lst: [string] = ["hello", "world"];
    let b = pass_through(lst);
    let _: string = b;
}
