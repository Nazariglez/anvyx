// @mode: check
// @expect: success

fn make_pair<T, U>(a: T, b: U) -> (T, U) {
    (a, b)
}

fn dup<T>(x: T) -> (T, T) {
    (x, x)
}

fn wrap<T>(x: T) -> T? {
    x
}

fn main() {
    let p: (int, string) = make_pair(1, "hello");
    let _: int = p.0;
    let _: string = p.1;

    let d: (bool, bool) = dup(true);

    let o: int? = wrap(42);
}
