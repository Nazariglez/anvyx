// @mode: check
// @expect: success

enum Wrapper<T> {
    Val(T),
    Empty,
}

enum Data<T> {
    Val { inner: [T] },
    Empty,
}

enum Wrap<T> {
    Items([T]),
    None,
}

fn extract<T>(w: Wrapper<T>, fallback: T) -> T {
    match w {
        Wrapper.Val(v) => v,
        Wrapper.Empty => fallback,
    }
}

fn main() {
    let w = Wrapper.Val(42);
    let a = extract(w, 0);
    let _: int = a;

    let s = Wrapper.Val("hello");
    let b = extract(s, "");
    let _: string = b;

    let nums: [int] = [1, 2, 3];
    let d = Data.Val { inner: nums };

    let strs: [string] = ["a", "b"];
    let e = Data.Val { inner: strs };

    let nums2: [int] = [1, 2, 3];
    let f = Wrap.Items(nums2);

    let strs2: [string] = ["a", "b"];
    let g = Wrap.Items(strs2);
}
