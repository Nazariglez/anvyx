// @mode: check
// @expect: success

fn get_val<T>(t: (val: T, extra: int)) -> T {
    t.val
}

fn get_both<T, U>(t: (first: T, second: U)) -> U {
    t.second
}

fn main() {
    let a = get_val((val: "hello", extra: 10));
    let _: string = a;

    let b = get_val((val: true, extra: 0));
    let _: bool = b;

    let c = get_both((first: 42, second: "world"));
    let _: string = c;
}
