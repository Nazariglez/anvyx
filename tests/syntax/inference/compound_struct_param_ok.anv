// @mode: check
// @expect: success

struct Box<T> {
    value: T,
}

fn unbox<T>(b: Box<T>) -> T {
    b.value
}

fn rebox<T>(b: Box<T>) -> Box<T> {
    Box { value: b.value }
}

fn main() {
    let b = Box { value: 42 };
    let x = unbox(b);
    let _: int = x;

    let c = Box { value: "hello" };
    let y = unbox(c);
    let _: string = y;

    let d = Box { value: true };
    let e = rebox(d);
    let _: bool = e.value;
}
