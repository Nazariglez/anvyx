// @mode: check
// @expect: success

dataref Box<T> {
    value: T,
}

dataref Node<T> {
    value: T,
    next: Node<T>?,
}

fn main() {
    let n = Node { value: 1, next: nil };
    let b = Box { value: 42 };
    let v: int = b.value;
    let s = Box { value: "hello" };
    let w: string = s.value;
}
