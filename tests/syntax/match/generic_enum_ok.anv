// @mode: check
// @expect: success

enum Option<T> { None, Some(T) }

fn main() {
    let opt: Option<int> = Option.Some(42);
    match opt {
        Option.Some(value) => {
            let x: int = value;
        },
        Option.None => {},
    }
    match opt {
        Option.None => {},
        Option.Some(x) => {
            let y: int = x;
        },
    }
}
