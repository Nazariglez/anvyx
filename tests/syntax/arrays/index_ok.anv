// @mode: check
// @expect: success

struct Board {
    rows: [[int; 3]; 2],
}

struct Bag {
    slots: [int; 4],
}

fn last_col(rows: [[int; 3]; 2]) -> int {
    rows[1][2]
}

fn main() {
    let fixed: [int; 3] = [1, 2, 3];
    let first = fixed[0];
    let third = fixed[2];

    let list: [float] = [1.0, 2.5, 3.5];
    let middle = list[1];

    let nested = [[1, 2], [3, 4]];
    let row = nested[1];
    let value = nested[0][0];

    let matrix: [[int; 3]; 2] = [[1, 2, 3], [4, 5, 6]];
    let diagonal = matrix[0][0] + matrix[1][1];

    let grids = [[[1, 2], [3, 4]], [[5, 6], [7, 8]]];
    let chained = grids[1][0][1];

    let total = diagonal + last_col(matrix) + chained;

    let board = Board {
        rows: [[1, 2, 3], [4, 5, 6]],
    };
    let brow = board.rows[1];
    let corner = board.rows[0][2];

    let bag = Bag { slots: [5, 6, 7, 8] };
    let last = bag.slots[3];

    let _ = first + third + value;
    let _ = middle;
    let _ = row;
    let _ = brow[0] + corner + last;
    let _ = total;
}
