// @mode: check
// @expect: success

extern type Point {
    init;
    x: float;
    y: float;
}

fn destructure_full(p: Point) {
    let Point { x, y } = p;
}

fn destructure_partial(p: Point) {
    let Point { x } = p;
}

fn main() {
    let p = Point { x: 1.0, y: 2.0 };
    destructure_full(p);
    destructure_partial(p);
}
