extern type Point {
    x: float;
    y: float;
    fn new(x: float, y: float) -> Self;
    fn origin() -> Self;
    fn move_by(var self, dx: float, dy: float);
}

fn main() {
    var p = Point.new(1.0, 2.0);
    let q = Point.origin();
    p.move_by(3.0, 4.0);
    let a: float = p.x;
}
