// @mode: check
// @expect: success

extern fn add(a: int, b: int) -> int;
extern fn tick();
extern fn greet(name: string) -> string;
extern fn make_list(size: int) -> [int];
extern fn make_map(key: string, value: int) -> [string: int];
extern fn identity(v: any) -> any;

fn main() {
    let x = add(1, 2);
    tick();
    let s = greet("world");
    let l: [int] = make_list(5);
    let m: [string: int] = make_map("a", 1);
    let y: int = identity(42);
}
