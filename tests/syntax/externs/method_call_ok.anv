// @mode: check
// @expect: success

extern type Point {
    x: float;
    y: float;
    fn move_by(var self, dx: float, dy: float);
    fn distance_to(self, other: Point) -> float;
}

extern fn make_point(x: float, y: float) -> Point;

fn main() {
    var p = make_point(1.0, 2.0);
    p.move_by(1.0, 2.0);
    let q = make_point(3.0, 4.0);
    let d: float = q.distance_to(p);
}
