// @mode: check
// @expect: success

extern type Vec2 {
    x: float;
    y: float;
    init;
    op Self + Self -> Self;
    op Self - Self -> Self;
    op Self * Self -> Self;
    op Self * float -> Self;
    op float * Self -> Self;
    op Self / Self -> Self;
    op Self / float -> Self;
    op Self == Self -> bool;
}

fn main() {
    let a = Vec2 { x: 1.0, y: 2.0 };
    let b = Vec2 { x: 3.0, y: 4.0 };
    let c = a + b;
    let d = a - b;
    let e = a * b;
    let f = a * 2.0;
    let g = 2.0 * a;
    let h = a / b;
    let i = a / 2.0;
}
