// @expect: success

extern type Point {
    x: float;
    y: float;
    fn new(x: float, y: float) -> Self;
    fn move_by(var self, dx: float, dy: float);
    fn distance_to(self, other: Point) -> float;
}

extern type Rect {
    x: float;
    y: float;
    w: float;
    h: float;
    fn new(x: float, y: float, w: float, h: float) -> Self;
    fn area(self) -> float;
}

fn main() {}
