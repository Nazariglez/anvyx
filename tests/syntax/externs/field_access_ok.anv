extern type Point {
    x: float;
    y: float;
    fn move_by(var self, dx: float, dy: float);
    fn distance_to(self, other: Point) -> float;
}

extern fn make_point(x: float, y: float) -> Point;

fn use_point(p: Point) -> float {
    p.x
}

fn main() {
    let p = make_point(1.0, 2.0);
    let a: float = p.x;
    let b: float = p.y;
}
