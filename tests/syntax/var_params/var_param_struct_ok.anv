// @mode: check
// @expect: success

struct Player {
    hp: int,

    fn reset(var self) {
        self.hp = 0;
    },

    fn apply_damage(var self, amount: int) {
        self.hp = self.hp - amount;
    },
}

fn swap(var a: int, var b: int) {
    let tmp = a;
    a = b;
    b = tmp;
}

fn main() {
    var p = Player { hp: 100 };
    p.apply_damage(10);
    p.reset();

    var x = 1;
    var y = 2;
    swap(x, y);
}
