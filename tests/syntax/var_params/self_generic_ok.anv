// @mode: check
// @expect: success

struct Wrapper<T> {
    value: T,

    fn new(value: T) -> Self {
        Wrapper { value: value }
    },

    fn get(self) -> T {
        self.value
    },

    fn replace(var self, new_value: T) {
        self.value = new_value;
    },
}

fn main() {
    var w = Wrapper.new(42);
    w.replace(100);
    let v: int = w.get();

    var s = Wrapper.new("hello");
    s.replace("world");
    let msg: string = s.get();
}
