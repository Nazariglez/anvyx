// @mode: check
// @expect: success

fn process(opt: int?) -> int {
    let Option.Some(x) = opt else { return 0; }
    x
}

fn main() {
    let _r = process(42);
    let opt: int? = 42;
    while true {
        let Option.Some(x) = opt else { break; }
        println(x);
        break;
    }

    let n = 42;
    let 42 = n else { return; }
    println(n);

    let t = (1, 2);
    let (1, y) = t else { return; }
    println(y);
}
