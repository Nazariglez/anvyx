// @mode: check
// @expect: success

fn main() {
    let opt: int? = 42;
    if let Option.Some(x) = opt {
        let _y: int = x;
    }
    if let Option.Some(x) = opt {
        println(x);
    } else {
        println(0);
    }

    let a: int? = nil;
    let b: int? = 42;
    if let Option.Some(x) = a {
        println(x);
    } else if let Option.Some(y) = b {
        println(y);
    } else {
        println(0);
    }
}
