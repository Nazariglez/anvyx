// @mode: check
// @expect: success

struct Point {
    x: int,
    y: int,
}

struct Inventory {
    items: [string],
}

fn main() {
    let a = Point { x: 1, y: 2 };
    let b = Point { x: 1, y: 2 };
    let eq = a == b;
    let neq = a != b;

    let xs: [string] = ["sword", "shield"];
    let ys: [string] = ["sword", "shield"];
    let c = Inventory { items: xs };
    let d = Inventory { items: ys };
    let eq2 = c == d;
}
