// @mode: check
// @expect: error
// @contains: Invalid operand type
// @contains: operator '-' cannot be applied to 'string'
// @contains: must be int, float, or double
// @contains: where T = string

fn sub<T>(a: T, b: T) -> T {
    return a - b;
}

fn main() {
    let x = sub("hello", "world");
}
