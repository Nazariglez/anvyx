// @mode: check
// @expect: error
// @contains: operator '-' cannot be applied to 'string'
// @contains: must be int, float, or double

struct Pair<T> {
    a: T,
    b: T,

    fn diff(self) -> T {
        return self.a - self.b;
    }
}

fn main() {
    let p = Pair { a: "x", b: "y" };
    let d = p.diff();
}
