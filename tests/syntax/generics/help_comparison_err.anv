// @mode: check
// @expect: error
// @contains: Invalid operand type
// @contains: operator '<' cannot be applied to 'bool'
// @contains: must be int, float, double, or string
// @contains: where T = bool

fn cmp<T>(a: T, b: T) -> bool {
    return a < b;
}

fn main() {
    let x = cmp(true, false);
}
