// @mode: run
// @expect: success
// @match-begin
// 2
// 1
// @match-end

fn do_swap(f: fn(var int, var int) -> void, var a: int, var b: int) {
    f(a, b);
}

fn swap(var a: int, var b: int) {
    let tmp = a;
    a = b;
    b = tmp;
}

fn main() {
    var x = 1;
    var y = 2;
    do_swap(swap, x, y);
    println(x);
    println(y);
}
