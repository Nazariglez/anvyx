// @mode: run
// @expect: success
// @match-begin
// 10
// 0
// @match-end

struct Point { x: int, y: int }

extend Point {
    fn move_x(var self, dx: int) {
        self.x = self.x + dx;
    }
}

fn main() {
    var a = Point { x: 0, y: 0 };
    let b = a;
    a.move_x(10);
    println(a.x);
    println(b.x);
}
