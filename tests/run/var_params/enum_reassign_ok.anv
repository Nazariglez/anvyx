// @mode: run
// @expect: success
// @match: done

enum Status { Idle, Running, Done }

fn finish(var s: Status) {
    s = Status.Done;
}

fn main() {
    var s = Status.Idle;
    finish(s);
    match s {
        Status.Idle => { println("idle"); },
        Status.Running => { println("running"); },
        Status.Done => { println("done"); },
    }
}
