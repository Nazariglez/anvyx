// @mode: run
// @expect: success
// @match-begin
// 15
// 0
// @match-end

struct Counter { value: int }

extend Counter {
    fn add_and_reset(var self, var amount: int) {
        self.value = self.value + amount;
        amount = 0;
    }
}

fn main() {
    var c = Counter { value: 10 };
    var n = 5;
    c.add_and_reset(n);
    println(c.value);
    println(n);
}
