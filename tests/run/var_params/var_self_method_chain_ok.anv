// @mode: run
// @expect: success
// @match: 13

struct Counter {
    value: int,

    fn add(var self, n: int) {
        self.value = self.value + n;
    }

    fn scale(var self, factor: int) {
        self.value = self.value * factor;
    }
}

fn main() {
    var c = Counter { value: 1 };
    c.add(4);
    c.scale(2);
    c.add(3);
    println(c.value);
}
