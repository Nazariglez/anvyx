// @mode: run
// @expect: success
// @match-begin
// 100
// 200
// 300
// @match-end

struct Point { x: int, y: int }
struct Container { point: Point }

fn triple_mutate(var a: int, var b: int, var c: int) {
    a = 100;
    b = 200;
    c = 300;
}

fn main() {
    var x = 0;
    var p = Point { x: 0, y: 0 };
    var c = Container { point: Point { x: 0, y: 0 } };
    triple_mutate(x, p.x, c.point.y);
    println(x);
    println(p.x);
    println(c.point.y);
}
