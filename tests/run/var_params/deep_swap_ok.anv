// @mode: run
// @expect: success
// @match-begin
// 20
// 10
// @match-end

struct Coord { x: int, y: int }
struct Nested { coord: Coord }
struct Root { inner: Nested }

fn swap(var a: int, var b: int) {
    let tmp = a;
    a = b;
    b = tmp;
}

fn main() {
    var r = Root { 
        inner: Nested { 
            coord: Coord { 
                x: 10, y: 20 
            } 
        } 
    };
    swap(r.inner.coord.x, r.inner.coord.y);
    println(r.inner.coord.x);
    println(r.inner.coord.y);
}
