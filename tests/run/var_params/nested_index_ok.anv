// @mode: run
// @expect: success
// @match-begin
// 2
// 2
// 3
// 5
// @match-end

fn mutate(var x: int) {
    x = x + 1;
}

fn main() {
    var matrix = [[1, 2], [3, 4]];
    mutate(matrix[0][0]);
    mutate(matrix[1][1]);
    println(matrix[0][0]);
    println(matrix[0][1]);
    println(matrix[1][0]);
    println(matrix[1][1]);
}
