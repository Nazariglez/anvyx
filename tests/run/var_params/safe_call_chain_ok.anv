// @mode: run
// @expect: success
// @match: 10

struct Val { n: int }

extend Val {
    fn set(var self, v: int) -> int {
        self.n = v;
        self.n
    }
}

fn maybe_val() -> Val? {
    Val { n: 0 }
}

fn main() {
    var v = maybe_val();
    let result = v?.set(10);
    match result {
        Option.Some(r) => println(r),
        Option.None => println(-1),
    }
}
