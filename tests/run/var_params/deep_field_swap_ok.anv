// @mode: run
// @expect: success
// @match-begin
// 20
// 10
// @match-end

struct Vec2 { x: int, y: int }
struct Entity { pos: Vec2 }

fn swap(var a: int, var b: int) {
    let tmp = a;
    a = b;
    b = tmp;
}

fn main() {
    var e = Entity { pos: Vec2 { x: 10, y: 20 } };
    swap(e.pos.x, e.pos.y);
    println(e.pos.x);
    println(e.pos.y);
}
