// @mode: run
// @expect: success
// @match: 1

struct Counter { value: int }

fn make_counter() -> Counter {
    Counter { value: 0 }
}

extend Counter {
    fn inc(var self) -> int {
        self.value = self.value + 1;
        self.value
    }
}

fn main() {
    let result = make_counter().inc();
    println(result);
}
