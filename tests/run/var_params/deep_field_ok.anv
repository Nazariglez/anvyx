// @mode: run
// @expect: success
// @match: 99

struct D { value: int }
struct C { d: D }
struct B { c: C }
struct A { b: B }

fn mutate(var x: int) {
    x = 99;
}

fn main() {
    var a = A { 
        b: B { 
            c: C { 
                d: D { 
                    value: 0 
                } 
            } 
        } 
    };
    mutate(a.b.c.d.value);
    println(a.b.c.d.value);
}
