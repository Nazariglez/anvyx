// @mode: run
// @expect: success
// @match-begin
// 99
// 0
// @match-end

struct Inner { value: int }
struct Outer { inner: Inner }

fn mutate_deep(var x: int) {
    x = 99;
}

fn main() {
    var a = Outer { inner: Inner { value: 0 } };
    let b = a;
    mutate_deep(a.inner.value);
    println(a.inner.value);
    println(b.inner.value);
}
