// @mode: run
// @expect: success
// @match-begin
// 1
// 2
// @match-end

struct Counter { value: int }

extend Counter {
    fn inc(var self) {
        self.value = self.value + 1;
    }
}

fn main() {
    var opt: Counter? = Counter { value: 0 };
    opt?.inc();
    match opt {
        Option.Some(c) => println(c.value),
        Option.None => println(-1),
    }
    var none: Counter? = nil;
    none?.inc();
    match none {
        Option.Some(c) => println(c.value),
        Option.None => println(2),
    }
}
