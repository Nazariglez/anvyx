// @mode: run
// @expect: success
// @match-begin:
// 42
// 0 
// @match-end

struct Inner { value: int }
struct Outer { inner: Inner }

extend Inner {
    fn set(var self, v: int) -> int {
        self.value = v;
        self.value
    }
}

extend Outer {
    fn get_inner(self) -> Inner {
        self.inner
    }
}

fn main() {
    let o = Outer { inner: Inner { value: 0 } };
    let result = o.get_inner().set(42);
    println(result);
    println(o.inner.value);
}
