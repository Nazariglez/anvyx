// @mode: run
// @expect: success
// @match-begin
// 55
// 10
// @match-end

struct Vec2 { x: int, y: int }
struct Entity { pos: Vec2, health: int }

extend Entity {
    fn heal_by_x(var self) {
        self.health = self.health + self.pos.x;
    }
}

fn mutate_deep(var val: int) {
    val = 55;
}

fn main() {
    var e = Entity { 
        pos: Vec2 { 
            x: 10, 
            y: 20 
        }, 
        health: 0 
    };
    e.heal_by_x();
    mutate_deep(e.pos.x);
    println(e.pos.x);
    println(e.health);
}
