// @mode: run
// @expect: success
// @match-begin
// 0
// 2
// 1
// @match-end

import std.mem;

dataref Node {
    value: int,
}

fn main() {
    println(mem.managed_count());
    var a = Node { value: 1 };
    var b = Node { value: 2 };
    println(mem.managed_count());
    b = a;
    println(mem.managed_count());
}
