// @mode: run
// @expect: success
// @match-begin
// .Some(5)
// .None<int>
// @match-end

struct Inner { value: int }
struct Outer { inner: Inner }

fn main() {
    let a: Outer? = Outer { inner: Inner { value: 5 } };
    println(a?.inner?.value);

    let b: Outer? = nil;
    println(b?.inner?.value);
}
