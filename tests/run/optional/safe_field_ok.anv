// @mode: run
// @expect: success
// @skip: safe field access wraps result in Option.Some() and always reads field 0 (findings.md #6, #7)
// @match-begin
// 10
// 20
// @match-end

struct Point { x: int, y: int }

fn main() {
    let p: Point? = Point { x: 10, y: 20 };
    let x = p?.x;
    let y = p?.y;
    println(x);
    println(y);
}
