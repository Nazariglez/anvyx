// @mode: run
// @expect: success
// @match-begin
// .Some(5.0)
// .None<float>
// .Some(10)
// .None<int>
// @match-end

struct Vec2 {
    x: float,
    y: float,

    fn length(self) -> float {
        (self.x * self.x + self.y * self.y).sqrt()
    }
}

extend int {
    fn doubled(self) -> int { self * 2 }
}

fn main() {
    let v: Vec2? = Vec2 { x: 3.0, y: 4.0 };
    let len = v?.length();
    println(len);

    let none_v: Vec2? = nil;
    let none_len = none_v?.length();
    println(none_len);

    let x: int? = 5;
    let d = x?.doubled();
    println(d);

    let y: int? = nil;
    let e = y?.doubled();
    println(e);
}
