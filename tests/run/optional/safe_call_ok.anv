// @mode: run
// @expect: success
// @match-begin
// 5.0
// nil
// @match-end

struct Vec2 {
    x: float,
    y: float,

    fn length(self) -> float {
        (self.x * self.x + self.y * self.y).sqrt()
    }
}

fn main() {
    let v: Vec2? = Vec2 { x: 3.0, y: 4.0 };
    let len = v?.length();
    println(len);

    let none_v: Vec2? = nil;
    let none_len = none_v?.length();
    println(none_len);
}
