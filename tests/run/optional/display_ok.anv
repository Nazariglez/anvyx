fn main() {
    let a: int? = 42;
    let b: int? = nil;
    let c: string? = "hello";
    let d: string? = nil;
    let e: bool? = true;
    let f: bool? = nil;
    let g: float? = 3.14;
    let h: float? = nil;
    println(a);
    println(b);
    println(c);
    println(d);
    println(e);
    println(f);
    println(g);
    println(h);
}
