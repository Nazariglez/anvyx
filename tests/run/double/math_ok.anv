// @mode: run
// @expect: success
// @contains: ok

fn main() {
    assert(0.0d.sin() == 0.0d);
    assert(0.0d.cos() == 1.0d);
    assert(0.0d.tan() == 0.0d);

    assert(0.0d.asin() == 0.0d);
    assert(1.0d.acos() == 0.0d);
    assert(0.0d.atan() == 0.0d);
    assert(1.0d.atan2(1.0d) > 0.0d);

    assert(3.7d.floor() == 3.0d);
    assert(3.2d.ceil() == 4.0d);
    assert(2.5d.round() == 3.0d);
    assert(2.9d.trunc() == 2.0d);

    assert(4.0d.sqrt() == 2.0d);
    assert(27.0d.cbrt() == 3.0d);
    assert(2.0d.pow(3.0d) == 8.0d);
    assert(0.0d.exp() == 1.0d);
    assert(1.0d.ln() == 0.0d);

    assert((-5.0d).abs() == 5.0d);
    assert(3.0d.min(7.0d) == 3.0d);
    assert(3.0d.max(7.0d) == 7.0d);
    assert(5.0d.clamp(0.0d, 3.0d) == 3.0d);
    assert((-1.0d).clamp(0.0d, 10.0d) == 0.0d);

    assert(0.0d.lerp(10.0d, 0.5d) == 5.0d);
    assert(0.0d.lerp(10.0d, 0.0d) == 0.0d);
    assert(0.0d.lerp(10.0d, 1.0d) == 10.0d);

    let rad = 180.0d.to_radians();
    let deg = rad.to_degrees();
    let diff = (deg - 180.0d).abs();
    assert(diff < 0.001d);

    println("ok");
}
