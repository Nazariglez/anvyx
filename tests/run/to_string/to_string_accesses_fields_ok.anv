// @mode: run
// @expect: success
// @match-begin
// Player 'Alice' (hp: 100)
// Player 'Bob' (hp: 0)
// @match-end

struct Player {
    name: string,
    hp: int,

    fn to_string(self) -> string {
        "Player '" + self.name + "' (hp: " + self.hp + ")"
    }
}

fn main() {
    println(Player { name: "Alice", hp: 100 });
    println(Player { name: "Bob", hp: 0 });
}
