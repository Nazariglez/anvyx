// @mode: run
// @expect: success
// @match-begin
// Point(x: 1, y: 2)
// Color(r: 0.5, g: 0.25, b: 0.75)
// Named(name: hello)
// Rect(origin: Point(x: 1, y: 2), size: Size(w: 10, h: 20))
// Point(x: 1, y: 2)
// nil
// [Point(x: 1, y: 2), Point(x: 3, y: 4)]
// @match-end

struct Point { x: int, y: int }
struct Color { r: float, g: float, b: float }
struct Named { name: string }
struct Size { w: int, h: int }
struct Rect { origin: Point, size: Size }

fn main() {
    println(Point { x: 1, y: 2 });
    println(Color { r: 0.5, g: 0.25, b: 0.75 });
    println(Named { name: "hello" });

    let r = Rect {
        origin: Point { x: 1, y: 2 },
        size: Size { w: 10, h: 20 },
    };
    println(r);

    let p: Point? = Point { x: 1, y: 2 };
    println(p);
    let none: Point? = nil;
    println(none);

    let points = [Point { x: 1, y: 2 }, Point { x: 3, y: 4 }];
    println(points);
}
