// @mode: run
// @expect: success
// @match-begin
// Point(x: 1, y: 2)
// rgb(0.5, 0.5, 0.5)
// rgb(1.0, 0.0, 0.0)
// Player 'Alice' (hp: 100)
// Player 'Bob' (hp: 0)
// Wrapper(inner: custom!, x: 42)
// @match-end

struct Point { x: int, y: int }

struct Color {
    r: float, g: float, b: float,

    fn to_string(self) -> string {
        "rgb(" + self.r + ", " + self.g + ", " + self.b + ")"
    }
}

struct Player {
    name: string,
    hp: int,

    fn to_string(self) -> string {
        "Player '" + self.name + "' (hp: " + self.hp + ")"
    }
}

struct Inner {
    val: int,

    fn to_string(self) -> string {
        "custom!"
    }
}

struct Wrapper { inner: Inner, x: int }

fn main() {
    println(Point { x: 1, y: 2 });
    println(Color { r: 0.5, g: 0.5, b: 0.5 });
    println(Color { r: 1.0, g: 0.0, b: 0.0 });

    println(Player { name: "Alice", hp: 100 });
    println(Player { name: "Bob", hp: 0 });

    println(Wrapper { inner: Inner { val: 99 }, x: 42 });
}
