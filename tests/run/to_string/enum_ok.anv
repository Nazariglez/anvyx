// @mode: run
// @expect: success
// @match-begin
// Direction.North
// Direction.South
// Direction.East
// Direction.West
// Message.Quit
// Message.Ping(42)
// Message.Move(10, 20)
// Event.Click(x: 10, y: 20)
// Event.Resize(width: 800, height: 600)
// [Shape.Circle(3.14), Shape.Point]
// Container(label: hello, shape: Shape.Point)
// @match-end

enum Direction {
    North,
    South,
    East,
    West,
}

enum Message {
    Quit,
    Ping(int),
    Move(int, int),
}

enum Event {
    Click { x: int, y: int },
    Resize { width: int, height: int },
}

enum Shape {
    Point,
    Circle(float),
}

struct Container {
    label: string,
    shape: Shape,
}

fn main() {
    println(Direction.North);
    println(Direction.South);
    println(Direction.East);
    println(Direction.West);

    println(Message.Quit);
    println(Message.Ping(42));
    println(Message.Move(10, 20));

    println(Event.Click { x: 10, y: 20 });
    println(Event.Resize { width: 800, height: 600 });

    let shapes = [Shape.Circle(3.14), Shape.Point];
    println(shapes);
    println(Container { label: "hello", shape: Shape.Point });
}
