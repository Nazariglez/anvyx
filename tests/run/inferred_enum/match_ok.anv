// @mode: run
// @expect: success
// @match-begin
// north
// some: 42
// none
// @match-end

enum Direction { North, South, East, West }

fn show(d: Direction) {
    match d {
        .North => println("north"),
        .South => println("south"),
        .East => println("east"),
        .West => println("west"),
    }
}

fn show_opt(o: Option<int>) {
    match o {
        .Some(v) => println("some: {v}"),
        .None => println("none"),
    }
}

fn main() {
    show(.North);
    show_opt(.Some(42));
    show_opt(.None);
}
