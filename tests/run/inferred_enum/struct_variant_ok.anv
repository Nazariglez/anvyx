// @mode: run
// @expect: success
// @match: 10

enum Event {
    Click { x: int, y: int },
    Key(string),
}

fn get_x(e: Event) -> int {
    match e {
        Event.Click { x, .. } => x,
        Event.Key(_) => 0,
    }
}

fn main() {
    let e: Event = .Click { x: 10, y: 20 };
    println(get_x(e));
}
