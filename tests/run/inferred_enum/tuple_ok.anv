// @mode: run
// @expect: success
// @match-begin
// .Some(42)
// Wrapper.Val(hello)
// @match-end

enum Wrapper<T> { Val(T), Empty }

fn show_opt(o: Option<int>) {
    println(o);
}

fn make_wrapper() -> Wrapper<string> {
    return .Val("hello");
}

fn main() {
    show_opt(.Some(42));
    println(make_wrapper());
}
