// @mode: run
// @expect: success
// @match-begin
// .None<int>
// .Some(42)
// .Some(42)
// Wrapper.Val(hello)
// @match-end

enum Wrapper<T> { Val(T), Empty }

fn show_opt(o: Option<int>) {
    println(o);
}

fn make_wrapper() -> Wrapper<string> {
    return .Val("hello");
}

fn main() {
    let a: Option<int> = .None;
    let b: Option<int> = .Some(42);
    println(a);
    println(b);

    show_opt(.Some(42));
    println(make_wrapper());
}
