// @mode: run
// @expect: success
// @match-begin
// got: 42
// nope
// 42
// 0
// @match-end

fn check(o: Option<int>) {
    if let .Some(v) = o {
        println(f"got: {v}");
    } else {
        println("nope");
    }
}

fn unwrap(o: Option<int>) -> int {
    let .Some(v) = o else { return 0; }
    v
}

fn main() {
    check(.Some(42));
    check(.None);
    println(unwrap(.Some(42)));
    println(unwrap(.None));
}
