// @mode: run
// @expect: success
// @match-begin
// Color.Red
// Color.Blue
// Color.Green
// @match-end

enum Color { Red, Green, Blue }

fn show(c: Color) {
    println(c);
}

fn make() -> Color {
    return .Green;
}

fn main() {
    let c: Color = .Red;
    println(c);
    show(.Blue);
    println(make());
}
