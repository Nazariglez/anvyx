// @mode: run
// @expect: success
// @match-begin
// 10
// 10
// @match-end

enum Event {
    Click { x: int, y: int },
    Key(string),
}

fn get_x_qualified(e: Event) -> int {
    match e {
        Event.Click { x, .. } => x,
        Event.Key(_) => 0,
    }
}

fn get_x_inferred(e: Event) -> int {
    match e {
        .Click { x, .. } => x,
        .Key(_) => 0,
    }
}

fn main() {
    let e: Event = .Click { x: 10, y: 20 };
    println(get_x_qualified(e));
    println(get_x_inferred(Event.Click { x: 10, y: 20 }));
}
