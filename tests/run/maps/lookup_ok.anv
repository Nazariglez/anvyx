// @mode: run
// @expect: success

fn main() {
    let m: [string: int] = [:];
    let v: int? = m["any"];
    assert(v == nil);

    let m2 = ["hp": 100, "mp": 50];
    let hp: int? = m2["hp"];
    let mp: int? = m2["mp"];
    assert(hp != nil);
    assert(mp != nil);

    let m3 = ["a": 1, "b": 2];
    let a: int? = m3["a"];
    let b: int? = m3["b"];
    let z: int? = m3["z"];
    assert(a != nil);
    assert(b != nil);
    assert(z == nil);
}
