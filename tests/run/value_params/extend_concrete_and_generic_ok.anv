// @mode: run
// @expect: success
// @match-begin
// true
// false
// @match-end

extend [int; 3] {
    fn is_triple(self) -> bool { true }
}

extend<T, N: int> [T; N] {
    fn is_triple(self) -> bool { false }
}

fn main() {
    println([1, 2, 3].is_triple());
    println([1, 2, 3, 4].is_triple());
}
