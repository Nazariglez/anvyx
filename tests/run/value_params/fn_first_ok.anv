// @mode: run
// @expect: success
// @match-begin
// 1
// hello
// 1
// 3
// @match-end

fn first<T, N: int>(arr: [T; N]) -> T {
    arr[0]
}

fn get_first_int<N: int>(arr: [int; N]) -> int {
    first(arr)
}

fn main() {
    println(first([1, 2, 3]));
    println(first(["hello", "world"]));
    println(first<int>([1, 2, 3]));
    println(get_first_int([3, 2, 1]));
}
