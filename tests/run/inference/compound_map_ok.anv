// @mode: run
// @expect: success
// @match-begin
// 100
// default
// @match-end

fn get_or<K, V>(m: [K: V], key: K, default: V) -> V {
    m[key] ?? default
}

fn main() {
    let m: [string: int] = ["hp": 100];
    println(get_or(m, "hp", 0));

    let n: [int: string] = [1: "one"];
    println(get_or(n, 2, "default"));
}
