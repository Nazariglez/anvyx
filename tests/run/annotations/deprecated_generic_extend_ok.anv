// @mode: run
// @expect: success
// @warn-contains: use of deprecated method 'old_len'
// @match: 3

extend<T> [T] {
    @deprecated("use count")
    fn old_len(self) -> int {
        var n = 0;
        for _ in self { n += 1; }
        n
    }
}

fn main() {
    let xs: [int] = [1, 2, 3];
    println(xs.old_len());
}
