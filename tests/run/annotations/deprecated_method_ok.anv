// @mode: run
// @expect: success
// @warn-contains: use of deprecated method 'old_get'
// @warn-contains: use of deprecated method 'old_extend'
// @match-begin
// 10
// 10
// @match-end

struct Box {
    value: int,

    @deprecated("use get_value")
    fn old_get(self) -> int { self.value }
}

extend Box {
    @deprecated("use new_extend")
    fn old_extend(self) -> int { self.value }
}

fn main() {
    let b = Box { value: 10 };
    println(b.old_get());
    println(b.old_extend());
}
