// @mode: run
// @expect: success
// @match-begin
// empty
// alias
// wildcard
// @match-end

import std.maps;
import std.maps as m;
import std.maps { * };

fn main() {
    var empty: [string: int] = maps.ordered();
    let v: int? = empty["any"];
    assert(v == nil);
    println("empty");

    var om = m.ordered<string, int>();
    om["x"] = 42;
    let alias_value: int? = om["x"];
    assert(alias_value != nil);
    println("alias");

    var wildcard = ordered<int, string>();
    wildcard[1] = "one";
    wildcard[2] = "two";
    let wildcard_value: string? = wildcard[1];
    assert(wildcard_value != nil);
    println("wildcard");
}
