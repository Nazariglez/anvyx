// @mode: run
// @expect: success
// @contains: ok

import std.maps;

fn main() {
    var m1: [string: int] = maps.ordered();
    m1["hp"] = 100;
    m1["mp"] = 50;
    let hp: int? = m1["hp"];
    let mp: int? = m1["mp"];
    assert(hp != nil);
    assert(mp != nil);

    var m2 = maps.ordered<string, int>();
    m2["hp"] = 100;
    m2["mp"] = 50;
    let hp2: int? = m2["hp"];
    let mp2: int? = m2["mp"];
    assert(hp2 != nil);
    assert(mp2 != nil);

    var m3: [string: int] = maps.ordered();
    m3["a"] = 1;
    m3["b"] = 2;
    m3["a"] = 99;
    let a: int? = m3["a"];
    let b: int? = m3["b"];
    assert(a != nil);
    assert(b != nil);

    println("ok");
}
