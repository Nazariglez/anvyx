// @mode: run
// @expect: success
// @contains: ok

import std.maps;

fn main() {
    var m = maps.ordered<string, int>();
    m["a"] = 1;
    m["b"] = 2;
    m["a"] = 99;
    let a: int? = m["a"];
    let b: int? = m["b"];
    let nothing: int? = nil;
    assert(a != nothing);
    assert(b != nothing);
    println("ok");
}
