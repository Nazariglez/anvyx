// @match-begin
// Vec3(1.0, 2.0, 3.0)
// 1.0
// 2.0
// 3.0
// Vec3(0.0, 0.0, 0.0)
// Vec3(5.0, 5.0, 5.0)
// @match-end

import std.linalg { Vec3 };

fn main() {
    let v = Vec3 { x: 1.0, y: 2.0, z: 3.0 };
    println(v);
    println(v.x);
    println(v.y);
    println(v.z);
    println(Vec3.zero());
    println(Vec3.splat(5.0));
}
