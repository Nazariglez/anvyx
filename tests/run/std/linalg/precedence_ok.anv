import std.linalg { Vec2 };

fn main() {
    let pos = Vec2 { x: 100.0, y: 200.0 };
    let vel = Vec2 { x: 10.0, y: -6.0 };
    let dt = 0.1;
    let new_pos = pos + vel * dt;
    println(new_pos.x);
    println(new_pos.y);
}
