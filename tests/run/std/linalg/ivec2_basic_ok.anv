// @mode: run
// @expect: success
// @match-begin
// IVec2(3, -4)
// 3
// -4
// IVec2(0, 0)
// IVec2(7, 7)
// IVec2(5, -3)
// IVec2(1, -5)
// IVec2(6, -8)
// IVec2(6, -8)
// IVec2(-3, 4)
// true
// 25
// 25
// @match-end

import std.linalg { IVec2 };

fn main() {
    let v = IVec2 { x: 3, y: -4 };
    println(v);
    println(v.x);
    println(v.y);
    println(IVec2.zero());
    println(IVec2.splat(7));
    println(v + IVec2 { x: 2, y: 1 });
    println(v - IVec2 { x: 2, y: 1 });
    println(v * 2);
    println(2 * v);
    println(-v);
    println(v == IVec2 { x: 3, y: -4 });
    println(v.dot(v));
    println(v.length_squared());
}
