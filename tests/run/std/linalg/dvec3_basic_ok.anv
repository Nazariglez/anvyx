// @mode: run
// @expect: success
// @match-begin
// DVec3(1.0, 2.0, 3.0)
// 1.0
// 2.0
// 3.0
// DVec3(0.0, 0.0, 0.0)
// DVec3(1.0, 1.0, 1.0)
// DVec3(2.0, 3.0, 4.0)
// DVec3(-1.0, -2.0, -3.0)
// DVec2(1.0, 2.0)
// DVec3(-4.0, 8.0, -4.0)
// 10.0
// @match-end

import std.linalg { DVec3 };

fn main() {
    let v = DVec3 { x: 1.0 as double, y: 2.0 as double, z: 3.0 as double };
    println(v);
    println(v.x);
    println(v.y);
    println(v.z);
    println(DVec3.zero());
    println(DVec3.one());
    println(v + DVec3 { x: 1.0 as double, y: 1.0 as double, z: 1.0 as double });
    println(-v);
    println(v.truncate());
    let w = DVec3 { x: 3.0 as double, y: 2.0 as double, z: 1.0 as double };
    println(v.cross(w));
    println(v.dot(w));
}
