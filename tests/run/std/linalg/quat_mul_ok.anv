// @mode: run
// @expect: success
// @match-begin
// -1.0
// 0.0
// 0.0
// @match-end

import std.linalg { Quat, Vec3 };

fn main() {
    let q1 = Quat.from_rotation_z(90.0.to_radians());
    let q2 = Quat.from_rotation_z(90.0.to_radians());
    let q = q1 * q2;
    let v = q * Vec3 { x: 1.0, y: 0.0, z: 0.0 };
    println(v.x.round());
    println(v.y.round());
    println(v.z.round());
}
