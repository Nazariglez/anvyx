// @mode: run
// @expect: success
// @match-begin
// IVec3(1, 2, 3)
// IVec2(1, 2)
// IVec3(2, 4, 6)
// IVec3(-1, -2, -3)
// 14
// @match-end

import std.linalg { IVec2, IVec3 };

fn main() {
    let v = IVec3 { x: 1, y: 2, z: 3 };
    println(v);
    println(v.truncate());
    println(v * 2);
    println(-v);
    println(v.length_squared());
}
