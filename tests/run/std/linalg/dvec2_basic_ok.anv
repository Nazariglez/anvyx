// @mode: run
// @expect: success
// @match-begin
// DVec2(1.5, 2.5)
// 1.5
// 2.5
// DVec2(0.0, 0.0)
// DVec2(3.0, 3.0)
// DVec2(2.0, 3.0)
// DVec2(3.0, 5.0)
// DVec2(3.0, 5.0)
// DVec2(-1.5, -2.5)
// true
// 8.5
// 8.5
// DVec2(-1.0, 0.0)
// @match-end

import std.linalg { DVec2 };

fn main() {
    let v = DVec2 { x: 1.5 as double, y: 2.5 as double };
    println(v);
    println(v.x);
    println(v.y);
    println(DVec2.zero());
    println(DVec2.splat(3.0 as double));
    println(v + DVec2 { x: 0.5 as double, y: 0.5 as double });
    println(v * (2.0 as double));
    println((2.0 as double) * v);
    println(-v);
    println(v == DVec2 { x: 1.5 as double, y: 2.5 as double });
    println(v.dot(v));
    println(v.length_squared());
    let up = DVec2 { x: 0.0 as double, y: 1.0 as double };
    println(up.perp());
}
