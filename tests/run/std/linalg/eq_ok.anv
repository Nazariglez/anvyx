// true
// @match-end

import std.linalg { Vec2 };

fn main() {
    let a = Vec2 { x: 1.0, y: 2.0 };
    let b = Vec2 { x: 1.0, y: 2.0 };
    let c = Vec2 { x: 3.0, y: 4.0 };
    println(a == b);
    println(a == c);
    println(a != b);
    println(a != c);
}
