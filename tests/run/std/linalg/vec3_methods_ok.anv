// @mode: run
// @expect: success
// @match-begin
// 5.0
// 32.0
// Vec3(-3.0, 6.0, -3.0)
// Vec3(0.0, 0.0, 1.0)
// Vec3(2.5, 3.5, 4.5)
// @match-end

import std.linalg { Vec3 };

fn main() {
    let a = Vec3 { x: 3.0, y: 4.0, z: 0.0 };
    println(a.length());

    let b = Vec3 { x: 1.0, y: 2.0, z: 3.0 };
    let c = Vec3 { x: 4.0, y: 5.0, z: 6.0 };
    println(b.dot(c));
    println(b.cross(c));

    let d = Vec3 { x: 0.0, y: 0.0, z: 5.0 };
    println(d.normalize());

    println(b.lerp(c, 0.5));
}
