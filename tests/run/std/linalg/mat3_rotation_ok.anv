// @mode: run
// @expect: success
// @match-begin
// Vec2(3.0, 4.0)
// Vec2(6.0, 8.0)
// @match-end

import std.linalg { Mat3, Vec2 };

fn main() {
    let identity_rot = Mat3.from_angle(0.0);
    println(identity_rot.transform_vector2(Vec2 { x: 3.0, y: 4.0 }));
    let scale = Mat3.from_scale(Vec2 { x: 2.0, y: 2.0 });
    println(scale.transform_vector2(Vec2 { x: 3.0, y: 4.0 }));
}
