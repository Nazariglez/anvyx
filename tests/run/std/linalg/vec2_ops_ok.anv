// @match-begin
// 4.0
// 6.0
// -2.0
// -2.0
// 3.0
// 8.0
// @match-end

import std.linalg { Vec2 };

fn main() {
    let a = Vec2 { x: 1.0, y: 2.0 };
    let b = Vec2 { x: 3.0, y: 4.0 };

    let c = a + b;
    println(c.x);
    println(c.y);

    let d = a - b;
    println(d.x);
    println(d.y);

    let e = a * b;
    println(e.x);
    println(e.y);
}
