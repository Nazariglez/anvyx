// @expect: success
// @match-begin
// Vec4(1.0, 2.0, 3.0, 4.0)
// 1.0
// 2.0
// 3.0
// 4.0
// Vec4(0.0, 0.0, 0.0, 0.0)
// Vec4(5.0, 5.0, 5.0, 5.0)
// @match-end

import std.linalg { Vec4 };

fn main() {
    let v = Vec4 { x: 1.0, y: 2.0, z: 3.0, w: 4.0 };
    println(v);
    println(v.x);
    println(v.y);
    println(v.z);
    println(v.w);
    println(Vec4.zero());
    println(Vec4.splat(5.0));
}
