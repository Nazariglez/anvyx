// @mode: run
// @expect: success
// @match-begin
// Vec2(1.0, 2.0)
// Vec3(1.0, 2.0, 3.0)
// @match-end

import std.linalg { Vec2, Vec3, Vec4 };

fn main() {
    let v3 = Vec3 { x: 1.0, y: 2.0, z: 3.0 };
    println(v3.truncate());

    let v4 = Vec4 { x: 1.0, y: 2.0, z: 3.0, w: 4.0 };
    println(v4.truncate());
}
