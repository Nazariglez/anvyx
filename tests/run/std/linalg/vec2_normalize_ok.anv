// @mode: run
// @expect: success
// @match-begin
// Vec2(1.0, 0.0)
// Vec2(0.0, 0.0)
// Vec2(2.0, 3.0)
// Vec2(-2.0, 1.0)
// @match-end

import std.linalg { Vec2 };

fn main() {
    let v = Vec2 { x: 5.0, y: 0.0 };
    println(v.normalize());

    let z = Vec2.zero();
    println(z.normalize_or_zero());

    let a = Vec2 { x: 1.0, y: 2.0 };
    let b = Vec2 { x: 3.0, y: 4.0 };
    println(a.lerp(b, 0.5));

    let p = Vec2 { x: 1.0, y: 2.0 };
    println(p.perp());
}
