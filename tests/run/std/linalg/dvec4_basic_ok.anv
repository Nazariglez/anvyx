// @mode: run
// @expect: success
// @match-begin
// DVec4(1.0, 2.0, 3.0, 4.0)
// 1.0
// 2.0
// 3.0
// 4.0
// DVec4(0.0, 0.0, 0.0, 0.0)
// DVec4(2.0, 2.0, 2.0, 2.0)
// DVec4(2.0, 3.0, 4.0, 5.0)
// DVec4(-1.0, -2.0, -3.0, -4.0)
// DVec3(1.0, 2.0, 3.0)
// 30.0
// @match-end

import std.linalg { DVec4 };

fn main() {
    let v = DVec4 { x: 1.0 as double, y: 2.0 as double, z: 3.0 as double, w: 4.0 as double };
    println(v);
    println(v.x);
    println(v.y);
    println(v.z);
    println(v.w);
    println(DVec4.zero());
    println(DVec4.splat(2.0 as double));
    println(v + DVec4 { x: 1.0 as double, y: 1.0 as double, z: 1.0 as double, w: 1.0 as double });
    println(-v);
    println(v.truncate());
    println(v.dot(v));
}
