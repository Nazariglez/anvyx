// @mode: run
// @expect: success
// @match-begin
// 5.0
// 7.0
// true
// @match-end

import std.linalg { Vec2 };

fn main() {
    let a = Vec2 { x: 1.0, y: 2.0 };
    let b = Vec2 { x: 3.0, y: 4.0 };
    let c = Vec2 { x: 1.0, y: 1.0 };
    let result = a + b + c;
    println(result.x);
    println(result.y);
    println(result == Vec2 { x: 5.0, y: 7.0 });
}
