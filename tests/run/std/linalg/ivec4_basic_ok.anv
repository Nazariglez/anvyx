// @mode: run
// @expect: success
// @match-begin
// IVec4(1, 2, 3, 4)
// IVec3(1, 2, 3)
// IVec4(3, 6, 9, 12)
// IVec4(-1, -2, -3, -4)
// 30
// @match-end

import std.linalg { IVec3, IVec4 };

fn main() {
    let v = IVec4 { x: 1, y: 2, z: 3, w: 4 };
    println(v);
    println(v.truncate());
    println(v * 3);
    println(-v);
    println(v.length_squared());
}
