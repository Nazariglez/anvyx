// Vec3(4.0, 6.0, 8.0)
// Vec3(-2.0, -2.0, -2.0)
// Vec3(3.0, 8.0, 15.0)
// Vec3(2.0, 4.0, 6.0)
// Vec3(2.0, 4.0, 6.0)
// Vec3(-1.0, -2.0, -3.0)
// true
// false
// @match-end

import std.linalg { Vec3 };

fn main() {
    let a = Vec3 { x: 1.0, y: 2.0, z: 3.0 };
    let b = Vec3 { x: 3.0, y: 4.0, z: 5.0 };
    println(a + b);
    println(a - b);
    println(a * b);
    println(a * 2.0);
    println(2.0 * a);
    println(-a);
    println(a == a);
    println(a == b);
}
