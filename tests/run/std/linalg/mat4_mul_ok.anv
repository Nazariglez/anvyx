// @mode: run
// @expect: success
// @match: Vec3(12.0, 26.0, 42.0)

import std.linalg { Mat4, Vec3 };

fn main() {
    let s = Mat4.from_scale(Vec3 { x: 2.0, y: 2.0, z: 2.0 });
    let t = Mat4.from_translation(Vec3 { x: 10.0, y: 20.0, z: 30.0 });
    let m = t * s;
    let p = Vec3 { x: 1.0, y: 3.0, z: 6.0 };
    println(m.transform_point3(p));
}
