// @mode: run
// @expect: success
// @match-begin
// 2.0
// 60.0
// Vec4(0.0, 0.0, 0.0, 1.0)
// Vec4(2.5, 3.5, 4.5, 5.5)
// @match-end

import std.linalg { Vec4 };

fn main() {
    let a = Vec4 { x: 2.0, y: 0.0, z: 0.0, w: 0.0 };
    println(a.length());

    let b = Vec4 { x: 1.0, y: 2.0, z: 3.0, w: 4.0 };
    let c = Vec4 { x: 4.0, y: 5.0, z: 6.0, w: 7.0 };
    println(b.dot(c));

    let d = Vec4 { x: 0.0, y: 0.0, z: 0.0, w: 5.0 };
    println(d.normalize());

    println(b.lerp(c, 0.5));
}
