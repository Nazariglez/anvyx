// @mode: run
// @expect: success
// @match-begin
// Vec3(1.0, 2.0, 3.0)
// Vec3(2.0, 6.0, 12.0)
// Vec3(11.0, 22.0, 33.0)
// @match-end

import std.linalg { Mat4, Vec3 };

fn main() {
    let p = Vec3 { x: 1.0, y: 2.0, z: 3.0 };
    let identity = Mat4.identity();
    println(identity.transform_point3(p));

    let s = Mat4.from_scale(Vec3 { x: 2.0, y: 3.0, z: 4.0 });
    println(s.transform_point3(p));

    let t = Mat4.from_translation(Vec3 { x: 10.0, y: 20.0, z: 30.0 });
    println(t.transform_point3(p));
}
