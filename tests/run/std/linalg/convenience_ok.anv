// @mode: run
// @expect: success
// @match-begin
// Vec2(1.0, 2.0)
// true
// Vec3(1.0, 2.0, 3.0)
// true
// Vec4(1.0, 2.0, 3.0, 4.0)
// true
// IVec2(1, 2)
// true
// IVec3(1, 2, 3)
// true
// IVec4(1, 2, 3, 4)
// true
// DVec2(1.0, 2.0)
// true
// DVec3(1.0, 2.0, 3.0)
// true
// DVec4(1.0, 2.0, 3.0, 4.0)
// true
// @match-end

import std.linalg {
    Vec2, Vec3, Vec4,
    IVec2, IVec3, IVec4,
    DVec2, DVec3, DVec4,
    vec2, vec3, vec4,
    ivec2, ivec3, ivec4,
    dvec2, dvec3, dvec4,
};

fn main() {
    let v2 = vec2(1.0, 2.0);
    println(v2);
    println(v2 == Vec2 { x: 1.0, y: 2.0 });

    let v3 = vec3(1.0, 2.0, 3.0);
    println(v3);
    println(v3 == Vec3 { x: 1.0, y: 2.0, z: 3.0 });

    let v4 = vec4(1.0, 2.0, 3.0, 4.0);
    println(v4);
    println(v4 == Vec4 { x: 1.0, y: 2.0, z: 3.0, w: 4.0 });

    let iv2 = ivec2(1, 2);
    println(iv2);
    println(iv2 == IVec2 { x: 1, y: 2 });

    let iv3 = ivec3(1, 2, 3);
    println(iv3);
    println(iv3 == IVec3 { x: 1, y: 2, z: 3 });

    let iv4 = ivec4(1, 2, 3, 4);
    println(iv4);
    println(iv4 == IVec4 { x: 1, y: 2, z: 3, w: 4 });

    let dv2 = dvec2(1.0 as double, 2.0 as double);
    println(dv2);
    println(dv2 == DVec2 { x: 1.0 as double, y: 2.0 as double });

    let dv3 = dvec3(1.0 as double, 2.0 as double, 3.0 as double);
    println(dv3);
    println(dv3 == DVec3 { x: 1.0 as double, y: 2.0 as double, z: 3.0 as double });

    let dv4 = dvec4(1.0 as double, 2.0 as double, 3.0 as double, 4.0 as double);
    println(dv4);
    println(dv4 == DVec4 { x: 1.0 as double, y: 2.0 as double, z: 3.0 as double, w: 4.0 as double });
}
