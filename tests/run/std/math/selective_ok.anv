// @mode: run
// @expect: success
// @contains: ok

import std.math { sin, cos, sqrt, abs, pow, min, max };

fn main() {
    assert(sqrt(4.0) == 2.0);
    assert(abs(-5.0) == 5.0);
    assert(pow(2.0, 3.0) == 8.0);
    assert(min(1.0, 2.0) == 1.0);
    assert(max(1.0, 2.0) == 2.0);
    assert(cos(0.0) == 1.0);
    assert(sin(0.0) == 0.0);

    assert(abs(-5) == 5);
    assert(min(1, 2) == 1);
    assert(max(1, 2) == 2);
    println("ok");
}
