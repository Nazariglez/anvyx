// @mode: run
// @expect: success
// @contains: ok

import std.math;

fn main() {
    assert(math.abs(-5) == 5);
    assert(math.abs(-5.0) == 5.0);

    assert(math.min(3, 8) == 3);
    assert(math.min(3.0, 8.0) == 3.0);

    assert(math.max(3, 8) == 8);
    assert(math.max(3.0, 8.0) == 8.0);

    assert(math.clamp(5, 0, 10) == 5);
    assert(math.clamp(5.0, 0.0, 10.0) == 5.0);

    println("ok");
}
