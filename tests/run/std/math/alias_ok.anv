// @mode: run
// @expect: success
// @contains: ok

import std.math as m;

fn main() {
    assert(m.sqrt(25.0) == 5.0);
    assert(m.abs(-10.0) == 10.0);
    assert(m.min(3.0, 7.0) == 3.0);
    assert(m.max(3.0, 7.0) == 7.0);

    assert(m.abs(-10) == 10);
    assert(m.min(3, 7) == 3);
    assert(m.max(3, 7) == 7);
    println("ok");
}
