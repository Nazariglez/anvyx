// @mode: run
// @expect: success
// @contains: true

import std.time;

fn main() {
    let before = time.elapsed();
    time.sleep(50);
    let after = time.elapsed();
    println(after - before >= 0.04d);

    let before2 = time.elapsed();
    time.sleep_secs(0.05d);
    let after2 = time.elapsed();
    println(after2 - before2 >= 0.04d);
}
