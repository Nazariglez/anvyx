// @mode: run
// @expect: success
// @contains: true

import std.time;

fn main() {
    let a = time.elapsed();
    let b = time.elapsed();
    println(b >= a);

    let c = time.elapsed_ms();
    let d = time.elapsed_ms();
    println(d >= c);

    let secs = time.elapsed();
    let ms = time.elapsed_ms();
    let diff = secs - (ms as double / 1000.0d);
    println(diff < 0.01d && diff > -0.01d);
}
