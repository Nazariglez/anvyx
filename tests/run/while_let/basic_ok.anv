// @mode: run
// @expect: success
// @match-begin
// a
// b
// c
// done
// @match-end

enum Item {
    Value(string),
    End,
}

fn main() {
    let items: [Item] = [Item.Value("a"), Item.Value("b"), Item.Value("c"), Item.End];
    var i = 0;
    while let Item.Value(s) = items[i] {
        println(s);
        i = i + 1;
    }
    println("done");
}
