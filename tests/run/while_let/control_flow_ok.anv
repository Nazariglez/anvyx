// @mode: run
// @expect: success
// @match-begin
// 20
// 40
// 10
// 20
// 30
// @match-end

enum Step {
    Next(int),
    Done,
}

fn get_step_skip(i: int) -> Step {
    if i < 5 {
        Step.Next((i + 1) * 10)
    } else {
        Step.Done
    }
}

fn get_step(i: int) -> Step {
    if i < 3 {
        Step.Next((i + 1) * 10)
    } else {
        Step.Done
    }
}

fn main() {
    var i = 0;
    while let Step.Next(val) = get_step_skip(i) {
        i = i + 1;
        if val % 20 != 0 { continue; }
        if val > 40 { break; }
        println(val);
    }

    var j = 0;
    while let Step.Next(val) = get_step(j) {
        println(val);
        j = j + 1;
    }
}
