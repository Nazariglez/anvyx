// @mode: run
// @expect: success
// @match-begin
// 10
// 20
// 30
// @match-end

enum Step {
    Next(int),
    Done,
}

fn get_step(i: int) -> Step {
    if i < 3 {
        Step.Next((i + 1) * 10)
    } else {
        Step.Done
    }
}

fn main() {
    var i = 0;
    while let Step.Next(val) = get_step(i) {
        println(val);
        i = i + 1;
    }
}
