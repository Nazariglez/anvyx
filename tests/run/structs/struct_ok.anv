// @mode: run
// @expect: success
// @match-begin
// 10
// 20
// 10
// 20
// 20
// 10
// @match-end

struct Point { x: int, y: int }

fn print_fields(p: Point) {
    println(f"{p.x}");
    println(f"{p.y}");
}

fn print_destructured(p: Point) {
    let Point { x, y } = p;
    println(f"{x}");
    println(f"{y}");
}

fn print_reordered(p: Point) {
    let Point { y, x } = p;
    println(f"{y}");
    println(f"{x}");
}

fn main() {
    let p = Point { x: 10, y: 20 };
    print_fields(p);
    print_destructured(p);
    print_reordered(p);
}
