// @mode: run
// @expect: success
// @match-begin
// 5
// 10
// 5
// 15
// @match-end

struct IVec2 { x: int, y: int }

fn make(x: int, y: int) -> IVec2 {
    IVec2 { x, y }
}

fn main() {
    let v = make(5, 10);
    println(v.x);
    println(v.y);

    let x = 5;
    let v2 = IVec2 { x, y: 15 };
    println(v2.x);
    println(v2.y);
}
