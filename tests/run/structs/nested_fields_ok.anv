// @mode: run
// @expect: success
// @match-begin
// 5
// 99
// @match-end

struct Vec2 { x: int, y: int }
struct Player { pos: Vec2, hp: int }

fn main() {
    let p = Player { pos: Vec2 { x: 5, y: 10 }, hp: 100 };
    println(f"{p.pos.x}");

    var p2 = Player { pos: Vec2 { x: 0, y: 0 }, hp: 100 };
    p2.pos.x = 99;
    println(p2.pos.x);
}
