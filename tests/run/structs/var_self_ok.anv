// @mode: run
// @expect: success
// @match-begin
// 100
// 90
// 0
// @match-end

struct Player {
    hp: int,

    fn get_hp(self) -> int { self.hp }

    fn apply_damage(var self, amount: int) {
        self.hp = self.hp - amount;
    }

    fn reset(var self) {
        self.hp = 0;
    }
}

fn main() {
    var p = Player { hp: 100 };
    println(p.get_hp());
    p.apply_damage(10);
    println(p.get_hp());
    p.reset();
    println(p.get_hp());
}
