// @mode: run
// @expect: success
// @match: ok

struct Inventory { 
    items: [string] = [],
    counts: [string: int] = [:] 
}

fn main() {
    let inv = Inventory {};
    var item_count = 0;
    for item in inv.items {
        item_count = item_count + 1;
    }
    assert(item_count == 0);
    let v: int? = inv.counts["any"];
    assert(v == nil);
    println("ok");
}
