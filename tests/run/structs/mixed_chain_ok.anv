// @mode: run
// @expect: success
// @match-begin
// 1
// 99
// 0
// 99
// @match-end

struct Data { items: [int; 3] }
struct Point { x: int, y: int }

fn main() {
    var a = Data { items: [1, 2, 3] };
    let b = a;
    a.items[0] = 99;
    println(b.items[0]);
    println(a.items[0]);

    var pts: [Point; 2] = [Point { x: 0, y: 0 }, Point { x: 1, y: 1 }];
    let q = pts;
    pts[0].x = 99;
    println(q[0].x);
    println(pts[0].x);
}
