// @mode: run
// @expect: success
// @match-begin
// 10
// 20
// Alice
// 100
// Bob
// 30
// @match-end

struct Point { x: int, y: int }
struct Player { name: string, score: int }

fn main() {
    // Basic shorthand
    let x = 10;
    let y = 20;
    let p = Point { x, y };
    println(p.x);
    println(p.y);

    // Shorthand with string and int
    let name = "Alice";
    let score = 100;
    let player = Player { name, score };
    println(player.name);
    println(player.score);

    // Mixed: shorthand + explicit
    let name2 = "Bob";
    let p2 = Player { name: name2, score: 30 };
    println(p2.name);
    println(p2.score);
}
