// @mode: run
// @expect: success
// @match-begin
// then-path
// then-defer
// else-path
// else-defer
// @match-end

fn go(flag: bool) {
    if flag {
        defer println("then-defer");
        println("then-path");
    } else {
        defer println("else-defer");
        println("else-path");
    }
}

fn main() {
    go(true);
    go(false);
}
