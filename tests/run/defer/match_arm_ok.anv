// @mode: run
// @expect: success
// @match-begin
// matched
// arm-defer
// fn-defer
// @match-end

fn check(x: int) {
    defer println("fn-defer");
    match x {
        1 => {
            defer println("arm-defer");
            println("matched");
        },
        _ => {},
    }
}

fn main() {
    check(1);
}
