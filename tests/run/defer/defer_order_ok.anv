// @mode: run
// @expect: success
// @match-begin
// start
// inner
// C
// B
// A
// 99
// @match-end

fn complex(x: int) -> int {
    defer println("A");
    println("start");
    defer println("B");
    if x > 0 {
        defer println("C");
        println("inner");
        return 99;
    }
    return 0;
}

fn main() {
    println(complex(1));
}
