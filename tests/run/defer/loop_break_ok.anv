// @mode: run
// @expect: success
// @match-begin
// 0
// loop-defer
// 1
// loop-defer
// done
// 0
// loop-defer
// 1
// loop-defer
// done
// fn-defer
// @match-end

fn while_break_case() {
    var i = 0;
    while i < 5 {
        defer println("loop-defer");
        println(i);
        i += 1;
        if i == 2 { break; }
    }
    println("done");
}

fn main() {
    defer println("fn-defer");
    for i in 0..3 {
        defer println("loop-defer");
        println(i);
        if i == 1 { break; }
    }
    println("done");
    while_break_case();
}
