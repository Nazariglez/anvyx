// @mode: run
// @expect: success
// @match-begin
// 0
// loop-defer
// 1
// loop-defer
// done
// fn-defer
// @match-end

fn main() {
    defer println("fn-defer");
    for i in 0..3 {
        defer println("loop-defer");
        println(i);
        if i == 1 { break; }
    }
    println("done");
}
