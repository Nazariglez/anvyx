// @mode: run
// @expect: success
// @contains: ok

fn main() {
    let a = 10;
    let b = 3;
    let sum = a + b;
    let diff = a - b;
    let prod = a * b;
    let quot = a / b;
    let rem = a % b;
    assert(sum == 13);
    assert(diff == 7);
    assert(prod == 30);
    assert(quot == 3);
    assert(rem == 1);
    println("ok");
}
