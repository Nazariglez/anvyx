// @mode: run
// @expect: success
// @match-begin
// pos: Point(x: 1, y: 2)
// entity: Entity(pos: Point(x: 0, y: 1))
// @match-end

struct Point { x: int, y: int }
struct Entity { pos: Point }

fn main() {
    let p = Point { x: 1, y: 2 };
    println(f"pos: {p}");

    let e = Entity { pos: Point { x: 0, y: 1 } };
    println(f"entity: {e}");
}
