// @mode: run
// @expect: success
// @contains: ok

import std.math { * };

fn main() {
    assert(sin(0.0) == 0.0);
    assert(cos(0.0) == 1.0);
    assert(sqrt(16.0) == 4.0);
    assert(floor(3.9) == 3.0);
    assert(ceil(3.1) == 4.0);
    assert(pow(3.0, 2.0) == 9.0);
    assert(log(1.0) == 0.0);
    println("ok");
}
