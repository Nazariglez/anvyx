// @mode: run
// @expect: success
// @contains: ok

fn main() {
    assert((-5).abs() == 5);
    assert(0.abs() == 0);
    assert(5.abs() == 5);

    assert(3.min(7) == 3);
    assert(7.min(3) == 3);
    assert(5.min(5) == 5);

    assert(3.max(7) == 7);
    assert(7.max(3) == 7);
    assert(5.max(5) == 5);

    assert(10.clamp(0, 5) == 5);
    assert((-3).clamp(0, 10) == 0);
    assert(3.clamp(0, 10) == 3);
    assert(0.clamp(0, 10) == 0);
    assert(10.clamp(0, 10) == 10);

    println("ok");
}
