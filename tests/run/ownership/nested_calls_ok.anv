// @mode: run
// @expect: success
// @match: 28

struct Wrapper { value: int }

fn wrap(v: int) -> Wrapper {
    Wrapper { value: v }
}

fn unwrap_val(w: Wrapper) -> int {
    w.value
}

fn scale_twice(w: Wrapper) -> Wrapper {
    wrap(unwrap_val(w) * 2)
}

fn main() {
    let w = wrap(7);
    let result = unwrap_val(scale_twice(scale_twice(w)));
    println(result);
}
