// @mode: run
// @expect: success
// @match: 1

extend<T> [[[T; 2]; 2]; 2] {
    fn corner(self) -> T { self[0][0][0] }
}

fn main() {
    let cube: [[[int; 2]; 2]; 2] = [
        [
            [1, 2], [3, 4]
        ], 
        [
            [5, 6], [7, 8]
        ]
    ];
    println(cube.corner());
}
