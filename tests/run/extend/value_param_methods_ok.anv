// @mode: run
// @expect: success
// @match-begin
// 3
// 5
// 1
// @match-end

extend<T, N: int> [T; N] {
    fn capacity(self) -> int { N }
    fn first(self) -> T { self[0] }
}

fn main() {
    let a = [1, 2, 3];
    let b = [1, 2, 3, 4, 5];
    println(a.capacity());
    println(b.capacity());
    println([1, 2, 3].first());
}
