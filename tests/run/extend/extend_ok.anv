// @mode: run
// @expect: success
// @match-begin
// 3.0
// 12.0
// 5
// 7
// 5
// 5
// @match-end

extend float {
    fn double_val(self) -> float { self * 2.0 }
    fn triple_val(self) -> float { self * 3.0 }
}

struct Pair<T> {
    first: T,
    second: T,
}

extend Pair<T> {
    fn sum(self) -> T {
        self.first + self.second
    }
}

fn main() {
    println(1.5.double_val());
    println(2.0.double_val().triple_val());

    let p: Pair<int> = Pair { first: 2, second: 3 };
    println(p.sum());
    let q: Pair<int> = Pair { first: 3, second: 4 };
    println(q.sum());

    let r: Pair<int> = Pair { first: 2, second: 3 };
    println(r.sum());
    let s: Pair<float> = Pair { first: 2.0, second: 3.0 };
    println(s.sum() as int);
}
