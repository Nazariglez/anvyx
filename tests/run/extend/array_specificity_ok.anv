// @mode: run
// @expect: success
// @match-begin
// concrete
// generic
// @match-end

extend<T> [T; 3] {
    fn label(self) -> string { "generic" }
}

extend [int; 3] {
    fn label(self) -> string { "concrete" }
}

fn main() {
    let a: [int; 3] = [1, 2, 3];
    let b: [string; 3] = ["a", "b", "c"];
    println(a.label());
    println(b.label());
}
