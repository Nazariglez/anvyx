// @mode: run
// @expect: success
// @match-begin
// 42
// hello
// @match-end

dataref Box<T> {
    value: T,
}

extend Box<T> {
    fn get(self) -> T {
        return self.value;
    }
}

fn main() {
    let a = Box { value: 42 };
    println(a.get());
    let b = Box { value: "hello" };
    println(b.get());
}
