extend [int; 3] {
    fn sum(self) -> int {
        var total = 0;
        for v in self {
            total += v;
        }
        total
    }
}

extend [int] {
    fn sum(self) -> int {
        var total = 0;
        for v in self {
            total += v;
        }
        total
    }
}

fn main() {
    let nums: [int] = [1, 2, 3];
    println(nums.sum());

    let array: [int; 3] = [1, 2, 3];
    println(array.sum());
}
