// @mode: run
// @expect: success
// @match: true

extend<T> [T] {
    fn contains(self, target: T) -> bool {
        for item in self {
            if item == target {
                return true;
            }
        }
        false
    }
}

fn main() {
    let nums: [int] = [1, 2, 3];
    println(nums.contains(2));
}
