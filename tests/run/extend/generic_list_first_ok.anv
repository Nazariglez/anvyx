// @mode: run
// @expect: success
// @match-begin
// 10
// nil
// @match-end

extend<T> [T] {
    fn first(self) -> T? {
        self.find(|x| x == x)
    }
}

fn main() {
    let a: [int] = [10, 20];
    let b: [int] = [];
    match a.first() {
        v? => println(v),
        nil => println("nil"),
    }
    match b.first() {
        v? => println(v),
        nil => println("nil"),
    }
}
