// @mode: run
// @expect: success
// @match-begin
// 1
// 10
// @match-end

struct Box<T> {
    value: T,
}

extend Box<T> {
    fn get(self) -> T { self.value }
    fn set(var self, v: T) { self.value = v; }
}

fn main() {
    var b: Box<int> = Box { value: 1 };
    println(b.get());
    b.set(10);
    println(b.get());
}
