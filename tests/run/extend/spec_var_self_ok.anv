// @mode: run
// @expect: success
// @match-begin
// 1
// 5
// 5
// @match-end

extend [int] {
    fn append_double(var self, v: int) {
        self.push(v);
        self.push(v);
    }
}

fn main() {
    var nums: [int] = [1];
    nums.append_double(5);
    for v in nums {
        println(v);
    }
}
