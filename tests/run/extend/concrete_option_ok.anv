// @mode: run
// @expect: success
// @match-begin
// true
// false
// 42
// @match-end

extend int? {
    fn is_some(self) -> bool {
        match self {
            _? => true,
            nil => false,
        }
    }

    fn unwrap_or(self, default: int) -> int {
        match self {
            v? => v,
            nil => default,
        }
    }
}

fn main() {
    let a: int? = 42;
    let b: int? = nil;
    println(a.is_some());
    println(b.is_some());
    println(b.unwrap_or(42));
}
