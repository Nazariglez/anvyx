// @mode: run
// @expect: success
// @match-begin
// true
// false
// 42
// @match-end

enum Maybe<T> {
    Some(T),
    None,
}

extend Maybe<T> {
    fn is_some(self) -> bool {
        match self {
            Maybe.Some(_) => true,
            Maybe.None => false,
        }
    }

    fn unwrap_or(self, default: T) -> T {
        match self {
            Maybe.Some(v) => v,
            Maybe.None => default,
        }
    }
}

fn main() {
    let a: Maybe<int> = Maybe.Some(42);
    let b: Maybe<int> = Maybe.None;
    println(a.is_some());
    println(b.is_some());
    println(b.unwrap_or(42));
}
