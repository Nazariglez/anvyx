// @mode: run
// @expect: success
// @match-begin
// true
// false
// Direction.Down
// @match-end

enum Direction {
    Up,
    Down,
    Left,
    Right,
}

extend Direction {
    fn is_horizontal(self) -> bool {
        match self {
            Direction.Left => true,
            Direction.Right => true,
            _ => false,
        }
    }

    fn opposite(self) -> Direction {
        match self {
            Direction.Up => Direction.Down,
            Direction.Down => Direction.Up,
            Direction.Left => Direction.Right,
            Direction.Right => Direction.Left,
        }
    }
}

fn main() {
    println(Direction.Left.is_horizontal());
    println(Direction.Up.is_horizontal());
    println(Direction.Up.opposite());
}
