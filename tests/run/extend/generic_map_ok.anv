// @mode: run
// @expect: success
// @match: 42

extend<K, V> [K: V] {
    fn put(var self, k: K, v: V) {
        self.insert(k, v);
    }
}

fn main() {
    var m: [string: int] = ["a": 1];
    m.put("x", 42);
    let val: int? = m["x"];
    match val {
        v? => println(v),
        nil => println(-1),
    }
}
