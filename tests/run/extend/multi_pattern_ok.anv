// @mode: run
// @expect: success
// @match-begin
// any-list
// nested
// @match-end

extend<T> [T] {
    fn kind(self) -> string { "any-list" }
}

extend<T> [[T]] {
    fn kind(self) -> string { "nested" }
}

fn main() {
    let a: [int] = [1, 2, 3];
    let inner: [int] = [1, 2];
    let b: [[int]] = [inner];
    println(a.kind());
    println(b.kind());
}
