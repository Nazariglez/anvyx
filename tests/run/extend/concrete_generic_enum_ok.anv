// @mode: run
// @expect: success
// @match-begin
// int-list
// string-list
// @match-end

extend [int] {
    fn describe(self) -> string { "int-list" }
}

extend [string] {
    fn describe(self) -> string { "string-list" }
}

fn main() {
    let ints: [int] = [1, 2];
    let strs: [string] = ["a"];
    println(ints.describe());
    println(strs.describe());
}
