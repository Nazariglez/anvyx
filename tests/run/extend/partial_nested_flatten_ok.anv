// @mode: run
// @expect: success
// @match-begin
// 1
// 2
// @match-end

extend<T> [[T]] {
    fn inner_sizes(self) -> [int] {
        var sizes: [int] = [];
        for inner in self {
            var n = 0;
            for item in inner {
                n += 1;
            }
            sizes.push(n);
        }
        sizes
    }
}

fn main() {
    let a: [int] = [1];
    let bc: [int] = [2, 3];
    var nested: [[int]] = [];
    nested.push(a);
    nested.push(bc);
    let result = nested.inner_sizes();
    for v in result {
        println(v);
    }
}
