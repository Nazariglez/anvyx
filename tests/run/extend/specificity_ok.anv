// @mode: run
// @expect: success
// @match-begin
// generic
// list-specific
// @match-end

extend<T> T? {
    fn describe(self) -> string { "generic" }
}

extend<T> [T]? {
    fn describe(self) -> string { "list-specific" }
}

fn main() {
    let a: string? = "hi";
    let b: [string]? = ["hi"];
    println(a.describe());
    println(b.describe());
}
