// @expect: success
// @match-begin
// 21
// 1
// @match-end

extend [[int; 3]; 2] {
    fn flat_sum(self) -> int {
        var total = 0;
        for row in self {
            for v in row {
                total += v;
            }
        }
        total
    }
}

extend<T> [[T; 3]; 2] {
    fn first_elem(self) -> T { self[0][0] }
}

fn main() {
    let grid: [[int; 3]; 2] = [
        [1, 2, 3], 
        [4, 5, 6]
    ];
    println(grid.flat_sum());
    println(grid.first_elem());
}
