// @match-end

struct Pair<T> {
    first: T,
    second: T,
}

extend Pair<T> {
    fn sum(self) -> T {
        self.first + self.second
    }
}

fn main() {
    let p: Pair<int> = Pair { first: 2, second: 3 };
    println(p.sum());

    let q: Pair<int> = Pair { first: 3, second: 4 };
    println(q.sum());
}
