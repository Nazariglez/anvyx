// @mode: run
// @expect: success
// @match-begin
// concrete
// generic
// @match-end

extend<T> T? {
    fn label(self) -> string { "generic" }
}

extend int? {
    fn label(self) -> string { "concrete" }
}

fn main() {
    let a: int? = 1;
    let b: string? = "x";
    println(a.label());
    println(b.label());
}
