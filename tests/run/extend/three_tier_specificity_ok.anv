// @mode: run
// @expect: success
// @match-begin
// generic
// list
// int-list
// @match-end

extend<T> T? {
    fn tag(self) -> string { "generic" }
}

extend<T> [T]? {
    fn tag(self) -> string { "list" }
}

extend [int]? {
    fn tag(self) -> string { "int-list" }
}

fn main() {
    let a: string? = "hi";
    let b: [string]? = ["hi"];
    let c: [int]? = [1];
    println(a.tag());
    println(b.tag());
    println(c.tag());
}
