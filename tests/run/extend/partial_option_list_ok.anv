// @mode: run
// @expect: success
// @match-begin
// true
// false
// false
// @match-end

extend<T> [T]? {
    fn has_list(self) -> bool {
        match self {
            _? => true,
            nil => false,
        }
    }
}

fn main() {
    let a: [int]? = [1, 2, 3];
    let b: [int]? = nil;
    let c: [string]? = nil;
    println(a.has_list());
    println(b.has_list());
    println(c.has_list());
}
