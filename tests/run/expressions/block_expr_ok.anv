// @mode: run
// @expect: success
// @match-begin
// 3
// 15
// 42
// hello world
// @match-end

fn main() {
    let x = { let a = 1; let b = 2; a + b };
    println(x);

    let y = { let a = { 10 }; a + 5 };
    println(y);

    println({ 42 });

    let z = { let s = "hello"; let t = " world"; s + t };
    println(z);
}
