// @mode: run
// @expect: success
// @match-begin
// one
// other
// hello
// @match-end

fn main() {
    let x = 1;
    let s = match x {
        1 => { "one" },
        2 => { "two" },
        _ => { "other" },
    };
    println(s);

    let y = 42;
    let s2 = match y {
        1 => { "one" },
        2 => { "two" },
        _ => { "other" },
    };
    println(s2);

    let name = "hello";
    let greeting = match name {
        "hi" => { "hi" },
        "hello" => { "hello" },
        _ => { "unknown" },
    };
    println(greeting);
}
