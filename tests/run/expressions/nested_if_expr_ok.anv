// @mode: run
// @expect: success
// @match-begin
// 1
// 2
// 3
// @match-end

fn main() {
    let a = true;
    let b = true;
    let x = if a { if b { 1 } else { 2 } } else { 3 };
    println(x);

    let x = if a { if false { 1 } else { 2 } } else { 3 };
    println(x);

    let x = if false { if b { 1 } else { 2 } } else { 3 };
    println(x);
}
