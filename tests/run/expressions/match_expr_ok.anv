// @mode: run
// @expect: success
// @match-begin
// one
// none
// fallback
// @match-end

enum Color {
    Red,
    Green,
    Blue,
}

fn main() {
    let c = Color.Red;
    let s = match c {
        Color.Red => { "one" },
        Color.Green => { "two" },
        Color.Blue => { "three" },
    };
    println(s);

    let opt: int? = nil;
    let val = match opt {
        Option.Some(v) => { v },
        Option.None => { 0 },
    };
    println(if val == 0 { "none" } else { "some" });

    let c2 = Color.Blue;
    let s2 = match c2 {
        Color.Red => { "red" },
        _ => { "fallback" },
    };
    println(s2);
}
