// @mode: run
// @expect: success
// @match-begin
// 15
// 5
// 50
// 5
// @match-end

struct Counter { value: int }

fn main() {
    var c = Counter { value: 10 };
    c.value += 5;
    println(c.value);
    c.value -= 10;
    println(c.value);
    c.value *= 10;
    println(c.value);
    c.value /= 10;
    println(c.value);
}
