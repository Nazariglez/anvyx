// @mode: run
// @expect: success
// @match-begin
// found: 2
// not found
// @match-end

fn main() {
    let xs: [int] = [1, 2, 3];
    let r = xs.find(|x| x > 1);
    match r {
        Option.Some(v) => println(f"found: {v}"),
        Option.None => println("not found"),
    }
    let r2 = xs.find(|x| x > 10);
    match r2 {
        Option.Some(v) => println(f"found: {v}"),
        Option.None => println("not found"),
    }
}
