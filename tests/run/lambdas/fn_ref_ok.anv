// @mode: run
// @expect: success
// @match-begin
// 10
// 4
// 3
// 6
// 10
// 4
// 3
// 1
// 2
// 3
// @match-end

fn twice(x: int) -> int {
    return x * 2;
}

fn inc(x: int) -> int {
    return x + 1;
}

fn triple(x: int) -> int {
    return x * 3;
}

fn apply(f: fn(int) -> int, x: int) -> int {
    return f(x);
}

fn show(x: int) {
    println(x);
}

fn main() {
    let f = twice;
    println(f(5));

    let fns: [fn(int) -> int] = [twice, inc, triple];
    for func in fns {
        println(func(2));
    }

    println(apply(twice, 5));

    let mixed: [fn(int) -> int] = [twice, |x: int| x + 1];
    for func in mixed {
        println(func(2));
    }

    let xs: [int] = [1, 2, 3];
    xs.for_each(show);
}
