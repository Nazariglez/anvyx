// @mode: run
// @expect: success
// @match-begin
// 10
// 15
// @match-end

fn triple(x: int) -> int {
    return x * 3;
}

struct Transform {
    apply: fn(int) -> int,
}

fn main() {
    let t = Transform { apply: |x| x * 2 };
    println(t.apply(5));
    let t2 = Transform { apply: triple };
    println(t2.apply(5));
}
