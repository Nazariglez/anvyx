// @mode: run
// @expect: success
// @match-begin
// 6
// 15
// @match-end

fn main() {
    let f = |x: int| -> int {
        let doubled = x * 2;
        doubled
    };
    println(f(3));

    let g = |a: int, b: int| -> int {
        let sum = a + b;
        let product = sum * a;
        product
    };
    println(g(3, 2));
}
