// @mode: run
// @expect: success
// @match-begin
// 0
// 42
// @match-end

dataref Counter {
    count: int = 0,
}

fn main() {
    var c = Counter {};
    let f = || c.count;   // captures c as alias
    println(f());         // 0
    c.count = 42;         // mutation through c; f sees it
    println(f());         // 42
}
