// @mode: run
// @expect: success
// @match: [Point(x: 10, y: 20), Point(x: 20, y: 40)]

struct Point { x: int, y: int }

fn scale(var p: Point) {
    p.x = p.x * 10;
    p.y = p.y * 10;
}

fn main() {
    var points: [Point] = [Point { x: 1, y: 2 }, Point { x: 2, y: 4 }];
    points.for_each(scale);
    println(points);
}
