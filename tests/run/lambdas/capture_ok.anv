// @expect: success
// @match-begin
// 15
// 10
// 11
// 10
// 60
// @match-end

fn main() {
    let base = 10;
    let add_base = |x: int| base + x;
    println(add_base(5));

    let n = 10;
    let f = || n;
    let g = || n + 1;
    println(f());
    println(g());
    println(f());

    let a = 3;
    let b = 4;
    let c = 5;
    let mul: fn() -> int = || a * b * c;
    println(mul());
}
