// @mode: run
// @expect: success
// @match-begin
// [1, 2, 3]
// [1, 2, 3, 4]
// @match-end

fn main() {
    var xs: [int] = [1, 2, 3];
    let f = || xs;        // captures xs; refcount = 2
    xs.push(4);           // COW: xs gets new allocation; f's capture stays at [1,2,3]
    println(f());         // must be [1, 2, 3]
    println(xs);          // must be [1, 2, 3, 4]
}
