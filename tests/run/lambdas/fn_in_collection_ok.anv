// @mode: run
// @expect: success
// @match-begin
// 6
// hello
// @match-end

fn greet() -> void {
    println("hello");
}

fn main() {
    let ops: [fn(int) -> int] = [|x: int| x * 2, |x: int| x + 1];
    println(ops[0](3));

    let handlers: [string: fn() -> void] = ["greet": greet];
    if let Option.Some(handler) = handlers["greet"] {
        handler();
    }
}
