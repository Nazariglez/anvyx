// @mode: run
// @expect: success
// @match-begin
// 6
// hello world
// @match-end

fn main() {
    let nums: [int] = [1, 2, 3];
    let sum = nums.fold(0, |acc, x| acc + x);
    println(sum);
    let words: [string] = ["hello", " ", "world"];
    let s = words.fold("", |acc, x| acc + x);
    println(s);
}
