// @mode: run
// @expect: success
// @match-begin
// [2, 4, 6]
// [3, 6, 9]
// [a!, b!]
// [8, 10]
// @match-end

fn main() {
    let xs: [int] = [1, 2, 3];
    println(xs.map(|x| x * 2));

    let factor = 3;
    println(xs.map(|x| x * factor));

    let ss: [string] = ["a", "b"];
    println(ss.map(|s| s + "!"));

    let ys: [int] = [1, 2, 3, 4, 5];
    println(ys.filter(|x| x > 3).map(|x| x * 2));
}
