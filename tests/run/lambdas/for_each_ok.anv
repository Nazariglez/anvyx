// @mode: run
// @expect: success
// @match-begin
// 1
// 2
// 3
// [2, 3, 4]
// [3, 5, 7]
// 1
// 2
// 3
// [1, 2, 3]
// [11, 12, 13]
// @match-end

fn add(var x: int, amount: int) {
    x = x + amount;
}

fn main() {
    let xs: [int] = [1, 2, 3];
    xs.for_each(|x| println(x));

    var ys: [int] = [1, 2, 3];
    ys.for_each(|var x| x += 1);
    println(ys);

    var zs: [int] = [1, 2, 3];
    zs.for_each(|var x| {
        x *= 2;
        x += 1;
    });
    println(zs);

    var ws: [int] = [1, 2, 3];
    ws.for_each(|var x| println(x));
    println(ws);

    var vs: [int] = [1, 2, 3];
    vs.for_each(|var x| add(x, 10));
    println(vs);
}
