// @mode: run
// @expect: success
// @match: ok

dataref Node {
    callback: fn() -> void,
}

fn noop() {}

fn make_cycle() {
    var n = Node { callback: noop };
    let f = || { n.callback(); };
    n.callback = f;
}

fn main() {
    var i = 0;
    while i < 1000 {
        make_cycle();
        i = i + 1;
    }
    println("ok");
}
