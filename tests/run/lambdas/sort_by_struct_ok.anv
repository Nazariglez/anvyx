// @mode: run
// @expect: success
// @match-begin
// [Point(x: 1, y: 30), Point(x: 2, y: 20), Point(x: 3, y: 10)]
// [Point(x: 3, y: 10), Point(x: 2, y: 20), Point(x: 1, y: 30)]
// @match-end

struct Point {
    x: int,
    y: int,
}

fn main() {
    var pts: [Point] = [Point { x: 3, y: 10 }, Point { x: 1, y: 30 }, Point { x: 2, y: 20 }];
    pts.sort_by(|a, b| a.x < b.x);
    println(pts);
    pts.sort_by(|a, b| a.y < b.y);
    println(pts);
}
