// @mode: run
// @expect: success
// @skip: fn ref equality compares by identity, not function index (findings.md #8)
// @match-begin
// true
// true
// false
// true
// @match-end

fn foo() -> int { 0 }
fn bar() -> int { 1 }

fn main() {
    let a: fn() -> int = foo;
    let b: fn() -> int = foo;
    println(a == b);
    println(a == a);
    println(a == bar);
    println(a != bar);
}
