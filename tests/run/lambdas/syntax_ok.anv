// @mode: run
// @expect: success
// @match-begin
// 10
// 6
// 15
// 13
// @match-end

fn main() {
    let f = |x: int| x * 2;
    println(f(5));

    let g = |x: int| -> int {
        let doubled = x * 2;
        doubled
    };
    println(g(3));

    let h = |a: int, b: int| -> int {
        let sum = a + b;
        let product = sum * a;
        product
    };
    println(h(3, 2));

    let x = 10;
    let outer = |a: int| -> fn(int) -> int {
        return |b| x + a + b;
    };
    let inner = outer(1);
    println(inner(2));
}
