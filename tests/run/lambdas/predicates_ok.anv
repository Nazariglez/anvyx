// @mode: run
// @expect: success
// @match-begin
// true
// false
// true
// false
// 3
// @match-end

fn main() {
    let xs: [int] = [1, 2, 3];
    println(xs.all(|x| x > 0));
    println(xs.all(|x| x > 2));
    println(xs.any(|x| x > 2));
    println(xs.any(|x| x > 10));

    let ys: [int] = [1, 2, 3, 4, 5];
    println(ys.count(|x| x > 2));
}
