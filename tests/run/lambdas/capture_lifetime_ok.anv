// @mode: run
// @expect: success
// @match-begin
// [1, 2, 3, 10]
// [1, 2, 3, 20]
// @match-end

fn make_appender(base: [int]) -> fn(int) -> [int] {
    return |x| {
        var result = base;
        result.push(x);
        return result;
    };
}

fn main() {
    let base: [int] = [1, 2, 3];
    let append = make_appender(base);
    println(append(10));
    println(append(20));
}
