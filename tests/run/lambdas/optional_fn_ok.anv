// @mode: run
// @expect: success
// @match-begin
// nil
// 10
// @match-end

fn maybe_double(use_it: bool) -> (fn(int) -> int)? {
    if use_it {
        return |x: int| x * 2;
    }
    return nil;
}

fn main() {
    let f = maybe_double(false);
    println(f);
    let g = maybe_double(true);
    if let Option.Some(cb) = g {
        println(cb(5));
    }
}
