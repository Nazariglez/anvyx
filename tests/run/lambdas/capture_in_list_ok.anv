// @mode: run
// @expect: success
// @match-begin
// 10
// 20
// 30
// @match-end

fn main() {
    let a = 10;
    let b = 20;
    var fns: [fn() -> int] = [];
    fns.push(|| a);
    fns.push(|| b);
    fns.push(|| a + b);
    println(fns[0]());  // 10
    println(fns[1]());  // 20
    println(fns[2]());  // 30
}
