// @mode: run
// @expect: success
// @match-begin
// true
// false
// true
// 4
// 3
// 1
// 6
// 5
// @match-end

fn pick(x: int) -> fn(int) -> int {
    return match x {
        1 => |y: int| y * 2,
        _ => |y: int| y + 2,
    };
}

fn main() {
    let f = || 1;
    let g = f;
    println(f == g);
    let h = || 1;
    println(f == h);
    println(f != h);

    let fns: [fn(int) -> int] = [|x: int| x * 2, |x: int| x + 1, |x: int| x - 1];
    for func in fns {
        println(func(2));
    }

    let p = pick(1);
    println(p(3));
    let q = pick(0);
    println(q(3));
}
