// @mode: run
// @expect: success
// @match-begin
// 10
// 0
// 10
// 5
// 10
// 5
// false
// true
// 100
// Hello Alice
// Hi Bob
// Hey Carol
// false
// true
// @match-end

const MAX_HP: float = 100.0;

fn add(a: int, b: int = 0) -> int {
    a + b
}

fn toggle(val: bool = false) -> bool { val }

fn make_unit(hp: float = MAX_HP) -> float { hp }

fn greet(name: string, greeting: string = "Hello", punct: string = " ") -> string {
    f"{greeting}{punct}{name}"
}

fn has_filter(filter: string? = nil) -> bool {
    match filter {
        Option.Some(_) => true,
        Option.None => false,
    }
}

fn main() {
    println(add(10));
    println(add(0));
    println(add(10, 0));
    println(add(0, 5));
    println(add(5, 5));
    println(add(3, 2));

    println(toggle());
    println(toggle(true));

    println(make_unit() as int);

    println(greet("Alice"));
    println(greet("Bob", "Hi"));
    println(greet("Carol", "Hey"));

    println(has_filter());
    println(has_filter("active"));
}
