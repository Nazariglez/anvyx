// @mode: run
// @expect: success
// @match: ok

fn add(a: int, b: int) -> int {
    a + b
}

fn sub(a: int, b: int) -> int {
    a - b
}

fn mul(a: int, b: int) -> int {
    a * b
}

fn twice(x: int) -> int {
    x * 2
}

fn quadruple(x: int) -> int {
    twice(twice(x))
}

fn answer() -> int {
    42
}

fn main() {
    assert(add(3, 4) == 7);
    assert(add(-1, 1) == 0);
    assert(sub(10, 3) == 7);
    assert(mul(3, 4) == 12);
    assert(quadruple(3) == 12);
    assert(answer() == 42);
    println("ok");
}
