// @mode: run
// @expect: success
// @match-begin
// 0
// 1
// 2
// done
// 1
// 2
// 4
// 5
// @match-end

fn main() {
    for n in 0..10 {
        if n == 3 {
            break;
        } else {
            println(n);
        }
    }
    println("done");

    for n in 1..6 {
        if n == 3 {
            continue;
        } else {
            println(n);
        }
    }
}
