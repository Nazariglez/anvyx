// @match-end

fn main() {
    for n in 0..5 {
        println(n);
    }
    for n in 0..=5 {
        println(n);
    }

    for n in rev 0..5 {
        println(n);
    }
    for n in rev 0..=5 {
        println(n);
    }

    for n in 0..10 step 2 {
        println(n);
    }

    for n in rev 0..10 step 3 {
        println(n);
    }
}
