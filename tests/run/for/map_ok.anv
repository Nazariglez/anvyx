// @mode: run
// @expect: success
// @match-begin
// hp: 100
// mp: 50
// 0: hp = 100
// 1: mp = 50
// @match-end

import std.maps;

fn main() {
    var m: [string: int] = maps.ordered();
    m["hp"] = 100;
    m["mp"] = 50;
    for (k, v) in m {
        println(f"{k}: {v}");
    }

    for (i, (k, v)) in m {
        println(f"{i}: {k} = {v}");
    }
}
