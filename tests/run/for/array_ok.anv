// @mode: run
// @expect: success
// @match-begin
// 10
// 20
// 30
// 30
// 20
// 10
// 10
// 30
// 50
// 0: 10
// 1: 20
// 2: 30
// @match-end

fn main() {
    let arr: [int; 3] = [10, 20, 30];
    for el in arr {
        println(el);
    }

    for el in rev arr {
        println(el);
    }

    let arr2: [int; 6] = [10, 20, 30, 40, 50, 60];
    for el in arr2 step 2 {
        println(el);
    }

    for (i, el) in arr {
        println(f"{i}: {el}");
    }
}
