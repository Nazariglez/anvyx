// @mode: run
// @expect: success
// @match-begin
// hello world
// size: 10
// pi is 3.14
// ff
// 00ff
// +42
// 11111111
//      hello
// @match-end

const GREETING = "hello" + " " + "world";

const SIZE = 10;
const LABEL = f"size: {SIZE}";

const PI = 3.14159;
const FORMATTED = f"pi is {PI:.2}";
const HEX = f"{255:x}";
const HEX_PAD = f"{255:04x}";
const SIGNED = f"{42:+}";
const BIN = f"{255:b}";
const NAME = "hello";
const PADDED = f"{NAME:>10}";

fn main() {
    println(GREETING);
    println(LABEL);
    println(FORMATTED);
    println(HEX);
    println(HEX_PAD);
    println(SIGNED);
    println(BIN);
    println(PADDED);
}
