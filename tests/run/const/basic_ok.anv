// 15
// 150
// 42
// 3.14
// true
// hello
// 42.0
// 3
// true
// false
// true
// 0
// 0
// @match-end

const X = 10;
const Y = X + 5;
const Z = X * Y;

const I = 42;
const F: float = 3.14;
const B = true;
const S = "hello";

const CAST_X = 42 as float;
const CAST_Y = 3.9 as int;

const LA = true;
const LB = false;
const LC = LA && !LB;
const LD = LA && LB;
const LE = LA || LB;

const SIZE = 5;

fn main() {
    println(X);
    println(Y);
    println(Z);

    println(I);
    println(F);
    println(B);
    println(S);

    println(CAST_X);
    println(CAST_Y);

    println(LC);
    println(LD);
    println(LE);

    let arr = [0; SIZE];
    println(arr[0]);
    println(arr[4]);
}
