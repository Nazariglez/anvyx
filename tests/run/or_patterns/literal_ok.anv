// @mode: run
// @expect: success
// @match-begin
// low
// low
// mid
// other
// @match-end

fn classify(n: int) -> string {
    match n {
        1 | 2 | 3 => "low",
        4 | 5 | 6 => "mid",
        _ => "other",
    }
}

fn main() {
    println(classify(1));
    println(classify(3));
    println(classify(5));
    println(classify(99));
}
