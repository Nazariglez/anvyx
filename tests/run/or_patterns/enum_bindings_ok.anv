// @mode: run
// @expect: success
// @match-begin
// 10
// 20
// 99
// @match-end

enum Event {
    Click(int),
    Touch(int),
    Hover(int),
}

fn get_x(e: Event) -> int {
    match e {
        Event.Click(x) | Event.Touch(x) => x,
        Event.Hover(x) => x + 1,
    }
}

fn main() {
    println(get_x(Event.Click(10)));
    println(get_x(Event.Touch(20)));
    println(get_x(Event.Hover(98)));
}
