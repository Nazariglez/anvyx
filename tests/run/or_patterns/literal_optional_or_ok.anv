// @mode: run
// @expect: success
// @match-begin
// zero or nil
// zero or nil
// positive
// positive
// @match-end

fn describe(v: int?) -> string {
    match v {
        nil | 0? => "zero or nil",
        _? => "positive",
    }
}

fn main() {
    let a: int? = nil;
    println(describe(a));
    println(describe(0));
    println(describe(42));
    println(describe(7));
}
