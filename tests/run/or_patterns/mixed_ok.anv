// @mode: run
// @expect: success
// @match-begin
// primary
// primary
// primary
// secondary
// other
// @match-end

enum Color { Red, Green, Blue, Yellow, Cyan, Magenta, White }

fn classify(c: Color) -> string {
    match c {
        Color.Red | Color.Green | Color.Blue => "primary",
        Color.Yellow | Color.Cyan | Color.Magenta => "secondary",
        _ => "other",
    }
}

fn main() {
    println(classify(Color.Red));
    println(classify(Color.Green));
    println(classify(Color.Blue));
    println(classify(Color.Yellow));
    println(classify(Color.White));
}
