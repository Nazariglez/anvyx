// @mode: run
// @expect: success
// @match-begin
// vertical
// horizontal
// vertical
// horizontal
// @match-end

enum Dir { North, South, East, West }

fn describe(d: Dir) -> string {
    match d {
        Dir.North | Dir.South => "vertical",
        Dir.East | Dir.West => "horizontal",
    }
}

fn main() {
    println(describe(Dir.North));
    println(describe(Dir.East));
    println(describe(Dir.South));
    println(describe(Dir.West));
}
