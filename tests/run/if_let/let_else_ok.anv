// @mode: run
// @expect: success
// @match-begin
// 42
// 0
// 42
// 0
// @match-end

fn process1(opt: int?) -> int {
    let Option.Some(x) = opt else { return 0; }
    x
}

fn process2(opt: int?) -> int {
    let v? = opt else { return 0; }
    v
}

fn main() {
    println(process1(42));
    println(process1(nil));
    println(process2(42));
    println(process2(nil));
}
