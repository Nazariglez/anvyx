// @mode: run
// @expect: success
// @match-begin
// a: 1
// b: 2
// none
// @match-end

fn check(a: int?, b: int?) {
    if let x? = a {
        println("a: {x}");
    } else if let y? = b {
        println("b: {y}");
    } else {
        println("none");
    }
}

fn main() {
    check(1, nil);
    check(nil, 2);
    check(nil, nil);
}
