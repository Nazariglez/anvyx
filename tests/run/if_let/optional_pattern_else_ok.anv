// @mode: run
// @expect: success
// @match-begin
// 42
// none
// 42
// none
// @match-end

fn check(opt: int?) {
    if let v? = opt {
        println(v);
    } else {
        println("none");
    }
}

fn check2(opt: int?) {
    if let Option.Some(x) = opt {
        println(x);
    } else {
        println("none");
    }
}

fn main() {
    check(42);
    check(nil);
    check2(42);
    check2(nil);
}
