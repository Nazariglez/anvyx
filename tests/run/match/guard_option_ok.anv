// @mode: run
// @expect: success
// @match-begin
// special
// other: 10
// none
// in range
// out: 100
// @match-end

fn main() {
    let a: int? = 42;
    match a {
        42? | 99? => { println("special"); },
        v? => { println(f"other: {v}"); },
        nil => { println("none"); },
    }

    let b: int? = 10;
    match b {
        42? | 99? => { println("special"); },
        v? => { println(f"other: {v}"); },
        nil => { println("none"); },
    }

    let c: int? = nil;
    match c {
        42? | 99? => { println("special"); },
        v? => { println(f"other: {v}"); },
        nil => { println("none"); },
    }

    let d: int? = 5;
    match d {
        1..10? | 20..30? => { println("in range"); },
        v? => { println(f"out: {v}"); },
        nil => { println("none"); },
    }

    let e: int? = 100;
    match e {
        1..10? | 20..30? => { println("in range"); },
        v? => { println(f"out: {v}"); },
        nil => { println("none"); },
    }
}
