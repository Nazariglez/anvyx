// @mode: run
// @expect: success
// @match-begin
// yes
// no
// other
// one
// two
// other
// greeting
// farewell
// unknown
// @match-end

fn main() {
    match true {
        true => { println("yes"); },
        false => { println("no"); },
    }
    match false {
        true => { println("yes"); },
        false => { println("no"); },
    }
    match false {
        true => { println("yes"); },
        _ => { println("other"); },
    }

    let a = 1;
    match a {
        1 => { println("one"); },
        2 => { println("two"); },
        _ => { println("other"); },
    }

    let b = 2;
    match b {
        1 => { println("one"); },
        2 => { println("two"); },
        _ => { println("other"); },
    }

    let c = 42;
    match c {
        1 => { println("one"); },
        2 => { println("two"); },
        _ => { println("other"); },
    }

    match "hello" {
        "hello" => { println("greeting"); },
        "bye" => { println("farewell"); },
        _ => { println("unknown"); },
    }
    match "bye" {
        "hello" => { println("greeting"); },
        "bye" => { println("farewell"); },
        _ => { println("unknown"); },
    }
    match "other" {
        "hello" => { println("greeting"); },
        "bye" => { println("farewell"); },
        _ => { println("unknown"); },
    }
}
