// @mode: run
// @expect: success
// @match-begin
// small
// medium
// big
// yes
// no
// yes
// negative
// zero
// positive
// low
// @match-end

fn classify(n: int) -> string {
    match n {
        0..10 => "small",
        10..=100 => "medium",
        _ => "big",
    }
}

fn in_range(n: int) -> string {
    match n {
        0..=10 => "yes",
        _ => "no",
    }
}

fn sign(n: int) -> string {
    match n {
        -100..0 => "negative",
        0..=0 => "zero",
        _ => "positive",
    }
}

fn classify_float(x: float) -> string {
    match x {
        0.0..1.0 => "low",
        _ => "high",
    }
}

fn main() {
    println(classify(5));
    println(classify(50));
    println(classify(200));

    println(in_range(0));
    println(in_range(11));
    println(in_range(10));

    println(sign(-5));
    println(sign(0));
    println(sign(42));

    println(classify_float(0.5));
}
