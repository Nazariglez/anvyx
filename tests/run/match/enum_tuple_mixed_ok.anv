// @mode: run
// @expect: success
// @match-begin
// origin: 0
// point: 5, 10
// @match-end

enum Shape {
    Point(int, int),
}

fn describe(s: Shape) -> string {
    match s {
        Shape.Point(0, y) => f"origin: {y}",
        Shape.Point(x, y) => f"point: {x}, {y}",
    }
}

fn main() {
    println(describe(Shape.Point(0, 0)));
    println(describe(Shape.Point(5, 10)));
}
