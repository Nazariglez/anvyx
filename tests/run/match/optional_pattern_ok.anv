// @mode: run
// @expect: success
// @match-begin
// 42
// none
// 42
// none
// hello
// empty
// has value
// none
// has value
// none
// @match-end

fn check_bind(opt: int?) {
    match opt {
        v? => {
            println(v);
        },
        nil => {
            println("none");
        },
    }
}

fn check_bind_explicit(opt: int?) {
    match opt {
        Option.Some(v) => {
            println(v);
        },
        nil => {
            println("none");
        },
    }
}

fn describe(s: string?) -> string {
    match s {
        v? => v,
        nil => "empty",
    }
}

fn check_wildcard(opt: int?) {
    match opt {
        _? => {
            println("has value");
        },
        nil => {
            println("none");
        },
    }
}

fn check_wildcard_explicit(opt: int?) {
    match opt {
        Option.Some(_) => {
            println("has value");
        },
        nil => {
            println("none");
        },
    }
}

fn main() {
    check_bind(42);
    check_bind(nil);
    check_bind_explicit(42);
    check_bind_explicit(nil);

    println(describe("hello"));
    println(describe(nil));

    check_wildcard(10);
    check_wildcard(nil);
    check_wildcard_explicit(10);
    check_wildcard_explicit(nil);
}
