// @mode: run
// @expect: success
// @match-begin
// negative
// small
// big
// up to ten
// above ten
// @match-end

fn classify(n: int) -> string {
    match n {
        ..0 => "negative",
        0..10 => "small",
        10.. => "big",
        _ => "unknown",
    }
}

fn main() {
    println(classify(-5));
    println(classify(5));
    println(classify(100));

    println(match 10 { ..=10 => "up to ten", _ => "above ten" });
    println(match 11 { ..=10 => "up to ten", _ => "above ten" });
}
