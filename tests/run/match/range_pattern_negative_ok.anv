// @mode: run
// @expect: success
// @match-begin
// negative
// zero
// positive
// @match-end

fn sign(n: int) -> string {
    match n {
        -100..0 => "negative",
        0..=0 => "zero",
        _ => "positive",
    }
}

fn main() {
    println(sign(-5));
    println(sign(0));
    println(sign(42));
}
