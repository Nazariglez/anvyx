// @mode: run
// @expect: success
// @match-begin
// matched
// got one
// @match-end

fn main() {
    let t1 = (1, "hello");
    match t1 {
        (1, "hello") => { println("matched"); },
        _ => { println("other"); },
    }

    let t2 = (1, "anything");
    match t2 {
        (1, _) => { println("got one"); },
        _ => { println("other"); },
    }
}
