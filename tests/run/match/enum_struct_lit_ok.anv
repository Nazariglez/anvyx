// @mode: run
// @expect: success
// @match-begin
// origin
// other: 5, 10
// @match-end

enum Shape {
    Point { x: int, y: int },
}

fn describe(s: Shape) -> string {
    match s {
        Shape.Point { x: 0, y: 0 } => "origin",
        Shape.Point { x, y } => f"other: {x}, {y}",
    }
}

fn main() {
    println(describe(Shape.Point { x: 0, y: 0 }));
    println(describe(Shape.Point { x: 5, y: 10 }));
}
