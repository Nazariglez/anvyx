// @mode: run
// @expect: success
// @match-begin
// 42
// none
// got: 10
// default
// @match-end

fn main() {
    let x: int? = 42;
    match x {
        Option.Some(v) => {
            println(v);
        },
        Option.None => {
            println("none");
        },
    }

    let y: int? = nil;
    match y {
        Option.Some(v) => {
            println("some");
        },
        Option.None => {
            println("none");
        },
    }

    let a: int? = 10;
    match a {
        Option.Some(v) => {
            println(f"got: {v}");
        },
        _ => {
            println("default");
        },
    }

    let b: int? = nil;
    match b {
        Option.Some(v) => {
            println(f"got: {v}");
        },
        _ => {
            println("default");
        },
    }
}
