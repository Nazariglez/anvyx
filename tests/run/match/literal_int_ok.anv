// @mode: run
// @expect: success
// @match-begin
// one
// two
// other
// @match-end

fn main() {
    let a = 1;
    match a {
        1 => { println("one"); },
        2 => { println("two"); },
        _ => { println("other"); },
    }

    let b = 2;
    match b {
        1 => { println("one"); },
        2 => { println("two"); },
        _ => { println("other"); },
    }

    let c = 42;
    match c {
        1 => { println("one"); },
        2 => { println("two"); },
        _ => { println("other"); },
    }
}
