// @mode: run
// @expect: success
// @match-begin
// got 42
// not 42
// @match-end

enum Wrapper {
    Val(int),
    Empty,
}

fn check(w: Wrapper) {
    if let Wrapper.Val(42) = w {
        println("got 42");
    } else {
        println("not 42");
    }
}

fn main() {
    check(Wrapper.Val(42));
    check(Wrapper.Val(10));
}
