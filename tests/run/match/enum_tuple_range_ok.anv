// @mode: run
// @expect: success
// @match-begin
// low
// mid
// high
// @match-end

enum Signal {
    Level(int),
}

fn classify(s: Signal) -> string {
    match s {
        Signal.Level(0..10) => "low",
        Signal.Level(10..100) => "mid",
        Signal.Level(_) => "high",
    }
}

fn main() {
    println(classify(Signal.Level(5)));
    println(classify(Signal.Level(50)));
    println(classify(Signal.Level(200)));
}
