// @mode: run
// @expect: success
// @match-begin
// special 42
// other 10
// none
// @match-end

enum Msg {
    Ping(int),
    Pong,
}

fn describe(m: Msg) -> string {
    match m {
        Msg.Ping(42) => "special 42",
        Msg.Ping(n) => f"other {n}",
        Msg.Pong => "none",
    }
}

fn main() {
    println(describe(Msg.Ping(42)));
    println(describe(Msg.Ping(10)));
    println(describe(Msg.Pong));
}
