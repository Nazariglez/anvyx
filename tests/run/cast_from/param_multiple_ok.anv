// @mode: run
// @expect: success
// @match: 6.0 6.0

struct Vec2 { x: float, y: float }

extend Vec2 {
    cast from(v: float) { Vec2 { x: v, y: v } }
    cast from(v: int) { Vec2 { x: v as float, y: v as float } }
}

fn add_vecs(a: as Vec2, b: as Vec2) -> Vec2 {
    Vec2 { x: a.x + b.x, y: a.y + b.y }
}

fn main() {
    let v = add_vecs(1.0, 5);
    println(f"{v.x} {v.y}");
}
