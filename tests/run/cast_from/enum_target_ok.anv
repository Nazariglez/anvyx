// @mode: run
// @expect: success
// @match: Red

enum Color { Red, Green, Blue }

extend Color {
    cast from(v: int) {
        match v {
            0 => Color.Red,
            1 => Color.Green,
            _ => Color.Blue,
        }
    }
}

fn main() {
    let c = 0 as Color;
    match c {
        Color.Red => println("Red"),
        Color.Green => println("Green"),
        Color.Blue => println("Blue"),
    }
}
