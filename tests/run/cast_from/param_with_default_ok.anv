// @mode: run
// @expect: success
// @match: 6.0 6.0 10.0

struct Vec2 { x: float, y: float }

extend Vec2 {
    cast from(v: float) { Vec2 { x: v, y: v } }
}

fn create(offset: as Vec2, scale: float = 1.0) -> float {
    (offset.x + offset.y) * scale
}

fn main() {
    let a = create(3.0);
    let b = create(3.0, 1.0);
    let c = create(1.0, 5.0);
    println(f"{a} {b} {c}");
}
