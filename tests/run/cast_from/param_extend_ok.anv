// @mode: run
// @expect: success
// @match: 4.0 4.0

struct Vec2 { x: float, y: float }

extend Vec2 {
    cast from(v: float) { Vec2 { x: v, y: v } }

    fn add(self, other: as Vec2) -> Vec2 {
        Vec2 { x: self.x + other.x, y: self.y + other.y }
    }
}

fn main() {
    let v = Vec2 { x: 1.0, y: 1.0 };
    let w = v.add(3.0);
    println(f"{w.x} {w.y}");
}
