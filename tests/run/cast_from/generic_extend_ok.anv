// @mode: run
// @expect: success
// @match-begin
// 42
// hello
// @match-end

struct IntBox { value: int }
struct StrBox { value: string }

extend IntBox {
    cast from(v: int) { IntBox { value: v } }
}

extend StrBox {
    cast from(v: string) { StrBox { value: v } }
}

fn main() {
    let a = 42 as IntBox;
    println(a.value);
    let b = "hello" as StrBox;
    println(b.value);
}
