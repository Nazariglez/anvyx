// @mode: run
// @expect: success
// @match-begin
// 3.0 3.0
// 5.0 5.0
// @match-end

struct Vec2 { x: float, y: float }

extend Vec2 {
    cast from(v: float) { Vec2 { x: v, y: v } }
    cast from(v: int) { Vec2 { x: v as float, y: v as float } }
}

fn main() {
    let v = 3.0 as Vec2;
    println(f"{v.x} {v.y}");
    let w = 5 as Vec2;
    println(f"{w.x} {w.y}");
}
