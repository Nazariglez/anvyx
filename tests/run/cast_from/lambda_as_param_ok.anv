// @mode: run
// @expect: success
// @match-begin
// (1.0, 1.0)
// (2.0, 3.0)
// @match-end

struct Vec2 { x: float, y: float }

extend Vec2 {
    cast from(v: float) { Vec2 { x: v, y: v } }
}

fn main() {
    let transform = |v: as Vec2| -> string { f"({v.x}, {v.y})" };
    println(transform(1.0));

    let v: Vec2 = Vec2 { x: 2.0, y: 3.0 };
    println(transform(v));
}
