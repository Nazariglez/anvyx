// @match-end

fn main() {
    let r = 0..10;
    println(r.contains(5));
    println(r.contains(10));
    println(r.contains(-1));

    let ri = 0..=10;
    println(ri.contains(5));
    println(ri.contains(10));
    println(ri.contains(0));

    let rf = 0.0..1.0;
    println(rf.contains(0.5));
    println(rf.contains(1.0));

    let ro = 5..;
    println(ro.contains(10));
    println(ro.contains(5));
    println(ro.contains(4));

    let rt = ..5;
    println(rt.contains(3));
    println(rt.contains(5));
    println(rt.contains(-1));

    let rti = ..=5;
    println(rti.contains(5));
    println(rti.contains(6));
    println(rti.contains(0));

    let rff = 1.5..;
    println(rff.contains(2.0));
    println(rff.contains(1.0));

    let rft = ..1.5;
    println(rft.contains(1.0));
    println(rft.contains(1.5));

    let rfti = ..=1.5;
    println(rfti.contains(1.5));
    println(rfti.contains(0.0));
}
