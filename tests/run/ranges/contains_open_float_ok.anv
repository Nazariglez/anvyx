// @mode: run
// @expect: success
// @match-begin
// true
// false
// true
// false
// true
// true
// @match-end

fn main() {
    let rf = 1.5..;
    println(rf.contains(2.0));
    println(rf.contains(1.0));

    let rt = ..1.5;
    println(rt.contains(1.0));
    println(rt.contains(1.5));

    let rti = ..=1.5;
    println(rti.contains(1.5));
    println(rti.contains(0.0));
}
