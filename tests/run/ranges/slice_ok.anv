// @match-begin
// 2
// 3
// 4
// 2
// 3
// 4
// 2
// 3
// 3
// 4
// 5
// 1
// 2
// 3
// @match-end

fn main() {
    let arr = [1, 2, 3, 4, 5];
    let view = arr[1..4];
    for n in view {
        println(n);
    }
    let view2 = arr[1..=3];
    for n in view2 {
        println(n);
    }

    var list: [int] = [1, 2, 3, 4];
    let sub = list[1..3];
    for n in sub {
        println(n);
    }

    let tail = arr[2..];
    for n in tail {
        println(n);
    }

    let head = arr[..3];
    for n in head {
        println(n);
    }
}
