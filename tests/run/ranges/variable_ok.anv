// @match-end

fn iter_range(r: Range<int>) {
    for n in r {
        println(n);
    }
}

fn iter_range_incl(r: RangeInclusive<int>) {
    for n in r {
        println(n);
    }
}

fn main() {
    let r = 0..3;
    for n in r {
        println(n);
    }
    let ri = 0..=3;
    for n in ri {
        println(n);
    }

    let r2 = 0..3;
    for n in rev r2 {
        println(n);
    }

    iter_range(0..3);
    iter_range_incl(0..=3);
}
