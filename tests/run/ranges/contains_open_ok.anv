// @mode: run
// @expect: success
// @match-begin
// true
// true
// false
// true
// false
// true
// true
// false
// true
// @match-end

fn main() {
    let rf = 5..;
    println(rf.contains(10));
    println(rf.contains(5));
    println(rf.contains(4));

    let rt = ..5;
    println(rt.contains(3));
    println(rt.contains(5));
    println(rt.contains(-1));

    let rti = ..=5;
    println(rti.contains(5));
    println(rti.contains(6));
    println(rti.contains(0));
}
