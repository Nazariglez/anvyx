// @mode: run
// @expect: success
// @match-begin
// 0
// 42
// default
// hello
// @match-end

fn main() {
    let a: int? = nil;
    println(a ?? 0);

    let b: int? = 42;
    println(b ?? 0);

    let c: string? = nil;
    println(c ?? "default");

    let d: string? = "hello";
    println(d ?? "default");
}
