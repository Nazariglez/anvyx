// @mode: run
// @expect: success
// @match-begin
// 5
// 10
// 1
// 42
// @match-end

fn main() {
    let a: int? = nil;
    var x = 0;
    x = a ?? 5;
    println(x);

    let b: int? = 10;
    x = b ?? 5;
    println(x);

    let c: int? = nil;
    println((c ?? 0) + 1);

    let d: int? = 42;
    println(d ?? 0);
}
