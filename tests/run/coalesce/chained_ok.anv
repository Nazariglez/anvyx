// @mode: run
// @expect: success
// @match-begin
// 99
// 20
// 10
// @match-end

fn main() {
    let a: int? = nil;
    let b: int? = nil;
    println(a ?? b ?? 99);

    let c: int? = nil;
    let d: int? = 20;
    println(c ?? d ?? 99);

    let e: int? = 10;
    let f: int? = nil;
    println(e ?? f ?? 99);
}
