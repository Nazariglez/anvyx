struct Rect {
    w: int,
    h: int,

    fn area(self) -> int {
        self.w * self.h
    }

    fn perimeter(self) -> int {
        (self.w + self.h) * 2
    }
}

fn make_rect(w: int, h: int) -> Rect {
    Rect { w: w, h: h }
}

fn main() {
    println(make_rect(3, 4).area());
    println(make_rect(3, 4).perimeter());
}
