// @mode: run
// @expect: success
// @match-begin
// true
// 0
// false
// 5
// 10
// true
// @match-end

struct Counter {
    value: int,

    fn get(self) -> int {
        self.value
    }

    fn doubled(self) -> int {
        self.value * 2
    }

    fn is_zero(self) -> bool {
        self.value == 0
    }

    fn is_positive(self) -> bool {
        self.value > 0
    }
}

fn main() {
    let c1 = Counter { value: 0 };
    println(c1.is_zero());
    println(c1.get());

    let c2 = Counter { value: 5 };
    println(c2.is_zero());
    println(c2.get());
    println(c2.doubled());
    println(c2.is_positive());
}
