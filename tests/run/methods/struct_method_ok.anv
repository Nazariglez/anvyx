// @mode: run
// @expect: success
// @match-begin
// 5.0
// (3, 4)
// @match-end

struct Vec2 {
    x: float,
    y: float,

    fn length(self) -> float {
        (self.x * self.x + self.y * self.y).sqrt()
    }
}

struct Point {
    x: int,
    y: int,

    fn as_tuple(self) -> (int, int) {
        (self.x, self.y)
    }
}

fn main() {
    let v = Vec2 { x: 3.0, y: 4.0 };
    println(v.length());

    let p = Point { x: 3, y: 4 };
    println(p.as_tuple());
}
