// @mode: run
// @expect: success
// @match: 99
// @skip: struct fields inside enum variant bindings use positional access, not named access

struct Point { x: int, y: int }
enum Shape { Dot(Point), None }

fn main() {
    var s = Shape.Dot(Point { x: 1, y: 2 });
    match s {
        Shape.Dot(var p) => {
            p.x = 99;
        },
        Shape.None => {},
    }
    match s {
        Shape.Dot(p) => {
            println(p.x);
        },
        Shape.None => {},
    }
}
