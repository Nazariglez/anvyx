// @mode: run
// @expect: success
// @match-begin
// moved 5 10
// hit 1 25
// @match-end

enum Event {
    Move { dx: int, dy: int },
    Hit { target: int, damage: int },
}

fn main() {
    let e1 = Event.Move { dx: 5, dy: 10 };
    let e2 = Event.Hit { target: 1, damage: 25 };

    match e1 {
        Event.Move { dx, dy } => { println("moved {dx} {dy}"); },
        Event.Hit { target, damage } => { println("hit {target} {damage}"); },
    }

    match e2 {
        Event.Move { dx, dy } => { println("moved {dx} {dy}"); },
        Event.Hit { target, damage } => { println("hit {target} {damage}"); },
    }
}
