// @mode: run
// @expect: success
// @match-begin
// playing
// menu
// paused
// @match-end

enum GameState {
    Menu,
    Playing,
    Paused,
}

fn main() {
    let s1 = GameState.Playing;
    let s2 = GameState.Menu;
    let s3 = GameState.Paused;

    match s1 {
        GameState.Menu => { println("menu"); },
        GameState.Playing => { println("playing"); },
        GameState.Paused => { println("paused"); },
    }

    match s2 {
        GameState.Menu => { println("menu"); },
        GameState.Playing => { println("playing"); },
        GameState.Paused => { println("paused"); },
    }

    match s3 {
        GameState.Menu => { println("menu"); },
        GameState.Playing => { println("playing"); },
        GameState.Paused => { println("paused"); },
    }
}
