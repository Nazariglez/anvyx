// @mode: run
// @expect: success
// @match-begin
// ping 42
// move 10 20
// @match-end

enum Message {
    Ping(int),
    Move(int, int),
}

fn main() {
    let m1 = Message.Ping(42);
    let m2 = Message.Move(10, 20);

    match m1 {
        Message.Ping(v) => { println("ping {v}"); },
        Message.Move(x, y) => { println("move {x} {y}"); },
    }

    match m2 {
        Message.Ping(v) => { println("ping {v}"); },
        Message.Move(x, y) => { println("move {x} {y}"); },
    }
}
