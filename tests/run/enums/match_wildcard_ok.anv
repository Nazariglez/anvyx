// @mode: run
// @expect: success
// @match-begin
// red
// other
// @match-end

enum Color {
    Red,
    Green,
    Blue,
}

fn main() {
    let c1 = Color.Red;
    let c2 = Color.Green;

    match c1 {
        Color.Red => { println("red"); },
        _ => { println("other"); },
    }

    match c2 {
        Color.Red => { println("red"); },
        _ => { println("other"); },
    }
}
