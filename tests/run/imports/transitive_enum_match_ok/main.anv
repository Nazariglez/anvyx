import source { active_status, inactive_status };

fn main() {
    let s1 = active_status();
    let s2 = inactive_status();
    let label1 = match s1 {
        Status.Active => "active",
        Status.Inactive => "inactive",
    };
    let label2 = match s2 {
        Status.Active => "active",
        Status.Inactive => "inactive",
    };
    println(label1);
    println(label2);
}
