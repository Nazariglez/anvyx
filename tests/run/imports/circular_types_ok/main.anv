// @mode: run
// @expect: success
// @match-begin
// Alice
// Bob
// @match-end

import manager { Manager };
import worker { Worker };

fn main() {
    let ws: [Worker] = [];
    let m = Manager { name: "Alice", workers: ws };
    let w = Worker { name: "Bob", manager: nil };
    println(m.name);
    println(w.name);
}
