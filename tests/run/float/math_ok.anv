// @mode: run
// @expect: success
// @contains: ok

fn main() {
    assert(0.0.sin() == 0.0);
    assert(0.0.cos() == 1.0);
    assert(0.0.tan() == 0.0);

    assert(0.0.asin() == 0.0);
    assert(1.0.acos() == 0.0);
    assert(0.0.atan() == 0.0);
    assert(1.0.atan2(1.0) > 0.0);

    assert(3.7.floor() == 3.0);
    assert(3.2.ceil() == 4.0);
    assert(2.5.round() == 3.0);
    assert(2.9.trunc() == 2.0);

    assert(4.0.sqrt() == 2.0);
    assert(27.0.cbrt() == 3.0);
    assert(2.0.pow(3.0) == 8.0);
    assert(0.0.exp() == 1.0);
    assert(1.0.ln() == 0.0);

    assert((-5.0).abs() == 5.0);
    assert(3.0.min(7.0) == 3.0);
    assert(3.0.max(7.0) == 7.0);
    assert(5.0.clamp(0.0, 3.0) == 3.0);
    assert((-1.0).clamp(0.0, 10.0) == 0.0);

    assert(0.0.lerp(10.0, 0.5) == 5.0);
    assert(0.0.lerp(10.0, 0.0) == 0.0);
    assert(0.0.lerp(10.0, 1.0) == 10.0);

    let rad = 180.0.to_radians();
    let deg = rad.to_degrees();
    let diff = (deg - 180.0).abs();
    assert(diff < 0.001);

    println("ok");
}
