// @mode: run
// @expect: success
// @match-begin
// 1
// -1
// 1
// @match-end

fn main() {
    // Shift wrapping: shift by 64 wraps to shift by 0 (masked with 63)
    println(1 << 64);

    // Arithmetic right shift preserves sign
    println(-1 >> 63);

    // Zero OR anything
    println(0 | 1);
}
