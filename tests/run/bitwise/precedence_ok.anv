// @mode: run
// @expect: success
// @match-begin
// 19
// 255
// true
// 12
// 252
// 4
// @match-end

fn main() {
    // Shift tighter than OR: (1 << 4) | 3 = 16 | 3 = 19
    println(1 << 4 | 3);

    // AND tighter than OR: (0xF0 & 0xFF) | 0x0F = 240 | 15 = 255
    println(0xF0 & 0xFF | 0x0F);

    // Shift tighter than comparison: (1 << 4) > 10 = 16 > 10 = true
    println(1 << 4 > 10);

    // AND tighter than XOR: (0xFF & 0x0F) ^ 0x03 = 15 ^ 3 = 12
    println(0xFF & 0x0F ^ 0x03);

    // XOR tighter than OR: (0x0F ^ 0x03) | 0xF0 = 12 | 240 = 252
    println(0x0F ^ 0x03 | 0xF0);

    // Shift tighter than AND: (1 << 2) & 7 = 4 & 7 = 4
    println(1 << 2 & 7);
}
