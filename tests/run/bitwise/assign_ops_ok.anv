// @mode: run
// @expect: success
// @match-begin
// 15
// 255
// 240
// 256
// 16
// @match-end

fn main() {
    var a = 255;
    a &= 15;
    println(a);

    var b = 0;
    b |= 255;
    println(b);

    var c = 255;
    c ^= 15;
    println(c);

    var d = 1;
    d <<= 8;
    println(d);
    d >>= 4;
    println(d);
}
