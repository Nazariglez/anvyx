// @mode: run
// @expect: success
// @match-begin
// -1
// 0
// 255
// @match-end

fn main() {
    // Double NOT is identity
    println(~~(-1));

    // XOR with self is zero
    println(42 ^ 42);

    // Alternating bits: 0xAA | (~0xAA & 0xFF) = 170 | 85 = 255
    let x = 0xAA;
    let y = ~x & 0xFF;
    println(x | y);
}
