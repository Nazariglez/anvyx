// @mode: run
// @expect: success
// @match-begin
// 3
// true
// 7
// 5
// false
// @match-end

fn main() {
    const FLAG_VISIBLE = 1 << 0;
    const FLAG_ACTIVE = 1 << 1;
    const FLAG_SOLID = 1 << 2;

    var flags = 0;

    // Set flags
    flags |= FLAG_VISIBLE | FLAG_ACTIVE;
    println(flags);

    // Check flag (parenthesization required — & is below ==)
    let is_visible = (flags & FLAG_VISIBLE) != 0;
    println(is_visible);

    // Toggle flag
    flags ^= FLAG_SOLID;
    println(flags);

    // Clear flag
    flags &= ~FLAG_ACTIVE;
    println(flags);

    // Check cleared
    let is_active = (flags & FLAG_ACTIVE) != 0;
    println(is_active);
}
