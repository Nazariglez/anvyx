// @mode: run
// @expect: success
// @match-begin
// 99
// 99
// @match-end

dataref Inner {
    value: int,
}

dataref Outer {
    inner: Inner,
}

fn main() {
    var i = Inner { value: 1 };
    var o = Outer { inner: i };
    i.value = 99;
    println("{o.inner.value}");
    println("{i.value}");
}
