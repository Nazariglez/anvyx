// @mode: run
// @expect: success
// @match-begin
// 0
// 1
// 2
// @match-end

dataref Counter {
    value: int,
}

extend Counter {
    fn get(self) -> int { self.value }
    fn inc(var self) { self.value = self.value + 1; }
}

fn main() {
    var c = Counter { value: 0 };
    println(c.get());
    c.inc();
    println(c.get());
    c.inc();
    println(c.get());
}
