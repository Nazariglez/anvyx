// @mode: run
// @expect: success
// @match-begin
// 42
// root
// 99
// leaf
// @match-end

dataref Node {
    value: int,
    label: string,
}

fn main() {
    let value = 42;
    let label = "root";
    let n = Node { value, label };
    println(n.value);
    println(n.label);

    let label2 = "leaf";
    let n2 = Node { value: 99, label: label2 };
    println(n2.value);
    println(n2.label);
}
