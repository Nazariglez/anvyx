// @mode: run
// @expect: success
// @match: ok

// It ceate a cycle that should make the test fails on exit if is not cleaned

enum Wrapper {
    Holds(Node),
    Empty,
}

dataref Node {
    next: Node?,
    child: Wrapper,
}

fn make_cycle() {
    var a = Node { next: nil, child: Wrapper.Empty };
    var b = Node { next: nil, child: Wrapper.Empty };
    a.next = b;
    b.child = Wrapper.Holds(a);
}

fn main() {
    var i = 0;
    while i < 1000 {
        make_cycle();
        i = i + 1;
    }
    println("ok");
}
