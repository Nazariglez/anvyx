// @mode: run
// @expect: success
// @match: ok

dataref Node<T> {
    value: T,
    next: Node<T>?,
}

fn make_cycle() {
    var a = Node { value: 1, next: nil };
    var b = Node { value: 2, next: nil };
    a.next = b;
    b.next = a;
}

fn main() {
    var i = 0;
    while i < 1000 {
        make_cycle();
        i = i + 1;
    }
    println("ok");
}
