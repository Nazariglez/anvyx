// @mode: run
// @expect: success
// @match: ok

dataref Node {
    links: [string: Node?],
}

fn make_cycle() {
    var a = Node { links: [:] };
    var b = Node { links: [:] };
    a.links["peer"] = b;
    b.links["peer"] = a;
}

fn main() {
    var i = 0;
    while i < 1000 {
        make_cycle();
        i = i + 1;
    }
    println("ok");
}
