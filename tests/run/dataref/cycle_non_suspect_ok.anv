// @mode: run
// @expect: success
// @match: ok

dataref Node {
    value: int,
    next: Node?,
}

fn make_chain_cycle() {
    // a <-> middle, middle only lives on a.next (no local). dropping "a" must reclaim both
    var a = Node { value: 1, next: nil };
    a.next = Node { value: 2, next: a };
}

fn main() {
    for _ in 0..500 {
        make_chain_cycle();
    }
    println("ok");
}
