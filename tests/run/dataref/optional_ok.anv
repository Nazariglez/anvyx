// @mode: run
// @expect: success
// @skip: safe field access wraps result in Option.Some() (findings.md #6)
// @match-begin
// true
// false
// 42
// @match-end

dataref Node {
    value: int,
}

fn main() {
    var node: Node? = nil;
    println(node == nil);
    node = Node { value: 42 };
    println(node == nil);
    println(node?.value);
}
