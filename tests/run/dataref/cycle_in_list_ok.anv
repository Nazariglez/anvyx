// @mode: run
// @expect: success
// @match: ok

dataref Node {
    next: Node?,
    items: [Node] = [],
}

fn make_cycle() {
    var a = Node { next: nil };
    var b = Node { next: nil };
    var items_a: [Node] = [b];
    var items_b: [Node] = [a];
    a.items = items_a;
    b.items = items_b;
}

fn main() {
    var i = 0;
    while i < 1000 {
        make_cycle();
        i = i + 1;
    }
    println("ok");
}
