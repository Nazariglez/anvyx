// @mode: run
// @expect: success
// @match-begin
// 3
// .Some(2)
// .Some(1)
// @match-end

dataref Node {
    value: int,
    next: Node?,
}

fn main() {
    var a = Node { value: 1, next: nil };
    var b = Node { value: 2, next: nil };
    var c = Node { value: 3, next: nil };
    b.next = a;
    c.next = b;
    println(c.value);
    println(c.next?.value);
    println(b.next?.value);
}
