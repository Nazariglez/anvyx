// @mode: run
// @expect: success
// @match: ok

struct Point {
    x: int,
    y: int,
}

dataref Node {
    value: int,
    next: Node?,
}

fn main() {
    let p = Point { x: 1, y: 2 };
    assert(p.x == 1);

    var a = Node { value: 10, next: nil };
    var b = Node { value: 20, next: nil };
    a.next = b;
    b.next = a;

    println("ok");
}
