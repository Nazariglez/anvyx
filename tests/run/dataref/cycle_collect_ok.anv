// @mode: run
// @expect: success
// @match: ok

dataref Node {
    next: Node?,
}

fn make_cycle() {
    var a = Node { next: nil };
    var b = Node { next: nil };
    a.next = b;
    b.next = a;
}

fn main() {
    var i = 0;
    while i < 1000 {
        make_cycle();
        i = i + 1;
    }
    println("ok");
}
