// @mode: run
// @expect: success
// @match-begin
// 10
// root
// 10
// @match-end

dataref Node {
    value: int,
    label: string,
}

fn main() {
    let n = Node { value: 10, label: "root" };
    let Node { value, label } = n;
    println(value);
    println(label);

    let Node { value: v } = n;
    println(v);
}
