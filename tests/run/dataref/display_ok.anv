// @mode: run
// @expect: success
// @match-begin
// Node(value: 42)
// Node[42]
// @match-end

dataref Node {
    value: int,
}

dataref FancyNode {
    value: int,

    fn to_string(self) -> string {
        return f"Node[{self.value}]";
    }
}

fn main() {
    let n = Node { value: 42 };
    println(f"{n}");

    let fancy = FancyNode { value: 42 };
    println(f"{fancy}");
}
