// @mode: run
// @expect: success
// @match: [              rgb(255, 128, 0)]

struct Color {
    r: int,
    g: int,
    b: int,

    fn to_string(self) -> string {
        "rgb({self.r}, {self.g}, {self.b})"
    }
}

fn main() {
    let c = Color { r: 255, g: 128, b: 0 };
    println("[{c:>30}]");
}
