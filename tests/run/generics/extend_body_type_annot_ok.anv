// @mode: run
// @expect: success
// @match-begin
// [1, 2, 3]
// [hello, world]
// @match-end

extend<T> [T] {
    fn copy_to_new(self) -> [T] {
        var result: [T] = [];
        for item in self {
            result.push(item);
        }
        result
    }
}

fn main() {
    let xs: [int] = [1, 2, 3];
    println(xs.copy_to_new());

    let ys: [string] = ["hello", "world"];
    println(ys.copy_to_new());
}
