{
  "grammars": [
    {
      "name": "anvyx",
      "camelcase": "Anvyx",
      "scope": "source.anvyx",
      "path": ".",
      "file-types": [
        "anv"
      ],
      "highlights": "queries/highlights.scm"
    }
  ],
  "metadata": {
    "version": "0.0.1",
    "license": "MIT",
    "description": "Tree-sitter grammar for the Anvyx programming language",
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-anvyx"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
